{
  "scenarios": [
    {
      "id": "sanity-homepage-up",
      "type": "sanity",
      "description": "Homepage is reachable and serves HTML",
      "path": "/",
      "method": "GET",
      "expectedStatus": 200,
      "bodyIncludes": ["<html", "</html>"]
    },
    {
      "id": "sanity-core-assets",
      "type": "sanity",
      "description": "Core assets are reachable",
      "path": "/script.js",
      "method": "GET",
      "expectedStatus": 200
    },
    {
      "id": "functional-search-page",
      "type": "functional",
      "description": "Search results page is available",
      "path": "/hc/en-us/search?query=test",
      "method": "GET",
      "expectedStatus": 200,
      "bodyIncludes": ["search"]
    },
    {
      "id": "functional-request-page",
      "type": "functional",
      "description": "New request page is available",
      "path": "/hc/en-us/requests/new",
      "method": "GET",
      "expectedStatus": 200
    },
    {
      "id": "positive-locale-default",
      "type": "positive",
      "description": "Default locale landing resolves",
      "path": "/hc/en-us",
      "method": "GET",
      "expectedStatus": 200
    },
    {
      "id": "negative-not-found",
      "type": "negative",
      "description": "Invalid path returns 404",
      "path": "/hc/en-us/this-path-should-not-exist-qa-check",
      "method": "GET",
      "expectedStatus": 404
    },
    {
      "id": "negative-invalid-query",
      "type": "negative",
      "description": "Malformed query does not return 5xx",
      "path": "/hc/en-us/search?query=%",
      "method": "GET",
      "expectedStatusNotIn": [500, 501, 502, 503, 504]
    }
  ]
}
