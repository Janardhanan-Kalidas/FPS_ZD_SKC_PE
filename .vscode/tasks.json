{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Zendesk: Login",
      "type": "shell",
      "command": "zcli",
      "args": [
        "login",
        "-i"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Zendesk: Preview Theme",
      "type": "shell",
      "command": "zcli",
      "args": [
        "themes:preview"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Zendesk: List Themes",
      "type": "shell",
      "command": "zcli",
      "args": [
        "themes:list"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}