{
  "name": "zendesk-skc-theme-tooling",
  "private": true,
  "type": "module",
  "scripts": {
    "version:theme": "node tooling/scripts/version-theme.mjs",
    "version:theme:dry": "node tooling/scripts/version-theme.mjs --dry-run",
    "version:theme:patch": "node tooling/scripts/version-theme.mjs --release-as patch",
    "version:theme:minor": "node tooling/scripts/version-theme.mjs --release-as minor",
    "version:theme:major": "node tooling/scripts/version-theme.mjs --release-as major",
    "backup:theme": "bash tooling/scripts/backup-zendesk-theme.sh",
    "deploy:theme": "bash tooling/scripts/deploy-zendesk-theme.sh",
    "deploy:gitlab:interactive": "bash tooling/scripts/trigger-gitlab-branch-deploy-interactive.sh",
    "rollback:theme": "bash tooling/scripts/rollback-zendesk-theme.sh"
  }
}