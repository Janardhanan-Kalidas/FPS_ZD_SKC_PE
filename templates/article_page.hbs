{{! ---------------------------------------------------------
   UNIVERSAL BREADCRUMBS – FINAL VERSION (CLICKABLE HOME)
   Updated by: Kalidas, Janardhanan
   Date: 20‑Mar‑2026

   Purpose:
   - Make "Home" clickable using help_center.url
   - Add home icon via CSS
   - Display native breadcrumbs beside Home
   - Work safely in ALL templates (home, category, section, article)
---------------------------------------------------------- }}

<div class="bg-gray-100 pt-5 pb-1">
  <div class="container">

    <div class="breadcrumbs-wrapper">

      {{!-- CLICKABLE HOME BREADCRUMB --}}
      <a href="{{help_center.url}}" class="bc-home">Home</a>

      {{!-- Native Zendesk breadcrumbs (must remain untouched) --}}
      <div class="bc-native">
        {{breadcrumbs}}
      </div>

    </div>

  </div>
</div>
<div class="container" id="page-container">
  <div class="article-3col-layout">

    {{! ======================================================= }}
    {{! LEFT SIDEBAR — Articles in this section                 }}
    {{! ======================================================= }}
    <aside class="article-left-sidebar" aria-label="Articles in this section">
      {{#isnt settings.article_sidebar 'none'}}
        {{#is settings.article_sidebar 'articles-in-section'}}
          <div class="article-sidebar-card">
            <h3 class="article-sidebar-heading">{{t 'articles_in_section'}}</h3>
            <ul class="article-sidebar-list">
              {{#each section.articles}}
                <li>
                  <a class="article-sidebar-link{{#is id ../article.id}} is-active{{/is}}" href="{{url}}">
                    {{title}}
                  </a>
                </li>
              {{/each}}
            </ul>
            <p class="article-sidebar-more">
              <a href="{{section.url}}">Show all articles</a>
            </p>
          </div>
        {{else}}
          <div data-element="navigation" data-template="{{settings.article_sidebar}}"></div>
        {{/is}}
      {{/isnt}}
    </aside>

    {{! ======================================================= }}
    {{! CENTER — Article content                               }}
    {{! ======================================================= }}
    <article class="article-main-content" itemscope itemtype="http://schema.org/Article">

      {{! Article header }}
      <div class="article-title py-4">
        <h1 title="{{article.title}}" itemprop="name">
          {{article.title}}
          {{#if article.internal}}
            <svg class="svg-icon text-base font-size-xl ml-1 mb-1" xmlns="http://www.w3.org/2000/svg" focusable="false" viewBox="0 0 16 16">
              <title>{{t 'internal'}}</title>
              <rect width="12" height="9" x="2" y="7" fill="currentColor" rx="1" ry="1"/>
              <path fill="none" stroke="currentColor" d="M4.5 7.5V4a3.5 3.5 0 017 0v3.5"/>
            </svg>
          {{/if}}
        </h1>

        {{! Row 1: Author | Date | Follow }}
        <div class="article-meta-row">
          {{#if settings.show_article_author}}
            <span class="article-meta-author">
              {{article.author.name}}
            </span>
            <span class="article-meta-sep">|</span>
          {{/if}}
          {{#isnt settings.article_metadata 'none'}}
            <span class="article-meta-date" data-created-at="{{article.created_at}}">
              {{date article.created_at}}
            </span>
          {{/isnt}}
          {{#if settings.show_follow_article}}
            <span class="article-meta-follow">
              {{subscribe}}
            </span>
          {{/if}}
        </div>

        {{! Row 2: Content tags }}
        {{#if (compare article.content_tags.length ">" 0)}}
          <ul class="article-tags-custom">
            {{#each article.content_tags}}
              <li>
                {{#link "search_result" content_tag_id=id class="article-tag-link"}}
                  {{name}}
                {{/link}}
              </li>
            {{/each}}
          </ul>
        {{/if}}

        {{! Row 3: Views | Likes | Share }}
        <div class="article-actions-row">
          {{! Views — populated via API }}
          <span class="article-action-item article-action-views" title="Article views">
            <img src="{{asset 'views.svg'}}" width="16" height="16" alt="" aria-hidden="true">
            <span class="article-action-count" id="article-view-count" data-article-id="{{article.id}}">0</span>
          </span>
          {{! Likes }}
          <span class="article-action-item article-action-likes" title="Helpful votes">
            <img src="{{asset 'thumb_up.svg'}}" width="16" height="16" alt="" aria-hidden="true">
            <span class="article-action-count">{{article.vote_sum}}</span>
          </span>
          {{! Share — right-aligned }}
          <button class="article-action-share" type="button" id="article-share-trigger" title="Share" aria-label="Open share options" aria-haspopup="dialog" aria-expanded="false" aria-controls="article-share-modal">
            <img src="{{asset 'share.svg'}}" width="16" height="16" alt="" aria-hidden="true">
            <span>Share</span>
          </button>
        </div>

        <div id="article-share-modal" class="article-share-modal" role="dialog" aria-modal="true" aria-labelledby="article-share-title" aria-hidden="true">
          <div class="article-share-modal__backdrop" data-share-close></div>
          <div class="article-share-modal__panel" role="document">
            <div class="article-share-modal__header">
              <h2 id="article-share-title" class="article-share-modal__title">Share</h2>
              <button type="button" class="article-share-modal__close" aria-label="Close share dialog" data-share-close>
                <span aria-hidden="true">&times;</span>
              </button>
            </div>
            <div class="article-share-modal__body">
              <a class="article-share-option" data-share-channel="facebook" target="_blank" rel="noopener noreferrer">
                <svg class="article-share-option__icon" viewBox="0 0 12 12" aria-hidden="true">
                  <path d="M6 0a6 6 0 01.813 11.945V7.63h1.552l.244-1.585H6.812v-.867c0-.658.214-1.242.827-1.242h.985V2.55c-.173-.024-.538-.075-1.23-.075-1.444 0-2.29.767-2.29 2.513v1.055H3.618v1.585h1.484v4.304A6.001 6.001 0 016 0z"></path>
                </svg>
                <span>Facebook</span>
              </a>
              <a class="article-share-option" data-share-channel="linkedin" target="_blank" rel="noopener noreferrer">
                <svg class="article-share-option__icon" viewBox="0 0 12 12" aria-hidden="true">
                  <path d="M10.8 0A1.2 1.2 0 0112 1.2v9.6a1.2 1.2 0 01-1.2 1.2H1.2A1.2 1.2 0 010 10.8V1.2A1.2 1.2 0 011.2 0h9.6zM8.09 4.356a1.87 1.87 0 00-1.598.792l-.085.133h-.024v-.783H4.676v5.727h1.778V7.392c0-.747.142-1.47 1.068-1.47.913 0 .925.854.925 1.518v2.785h1.778V7.084l-.005-.325c-.05-1.38-.456-2.403-2.13-2.403zm-4.531.142h-1.78v5.727h1.78V4.498zm-.89-2.846a1.032 1.032 0 100 2.064 1.032 1.032 0 000-2.064z"></path>
                </svg>
                <span>LinkedIn</span>
              </a>
              <a class="article-share-option" data-share-channel="twitter" target="_blank" rel="noopener noreferrer">
                <svg class="article-share-option__icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M14.095479 10.316482L22.286354 1h-1.940718l-7.115352 8.087682L7.551414 1H1l8.589488 12.231093L1 23h1.940717l7.509372-8.542861L16.448587 23H23L14.095479 10.316482zM11.436522 13.338465l-.871624-1.218704-6.924311-9.68815h2.981339l5.58978 7.82155.867949 1.218704 7.26506 10.166271h-2.981339l-5.926673-8.299271z"></path>
                </svg>
                <span>Twitter</span>
              </a>
              <a class="article-share-option" data-share-channel="xing" target="_blank" rel="noopener noreferrer">
                <span class="article-share-option__icon article-share-option__icon--text" aria-hidden="true">X</span>
                <span>XING</span>
              </a>
              <a class="article-share-option" data-share-channel="email">
                <span class="article-share-option__icon article-share-option__icon--text" aria-hidden="true">@</span>
                <span>Email</span>
              </a>
              <button type="button" class="article-share-option article-share-option--copy" id="article-share-copy-link">
                <img src="{{asset 'share.svg'}}" width="16" height="16" alt="" aria-hidden="true" class="article-share-option__icon-img">
                <span>Copy Link</span>
              </button>
            </div>
          </div>
        </div>
        <span id="share-toast" class="article-share-toast">Link copied!</span>

      </div>

      {{! Article content }}
      <section class="content article-content mb-6" itemprop="articleBody">

        {{! Table of Contents }}
        {{~#isnt settings.table_of_contents_style 'none'}}
          {{~#isnt settings.table_of_contents_style 'sidebar-left'}}
            {{~#isnt settings.table_of_contents_style 'sidebar-right'}}
              <div
                class="table-of-contents"
                data-element="table-of-contents"
                data-template="table-of-contents"
                data-selector=".content h2">
              </div>
            {{/isnt~}}
          {{/isnt~}}
        {{/isnt~}}

        {{! Article content }}
        {{article.body}}

        {{! Attachments }}
        {{#if attachments}}
          <ul class="list-unstyled my-6">
            {{#each attachments}}
              <li class="list-item">
                <svg class="svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" aria-hidden="true">
                  <path fill="none" stroke="currentColor" stroke-linecap="round" d="M9.5 4v7.7c0 .8-.7 1.5-1.5 1.5s-1.5-.7-1.5-1.5V3C6.5 1.6 7.6.5 9 .5s2.5 1.1 2.5 2.5v9c0 1.9-1.6 3.5-3.5 3.5S4.5 13.9 4.5 12V4"/>
                </svg>
                <a class="mr-2" href="{{url}}" target="_blank">{{name}}</a><span class="font-size-md text-gray-600">{{size}}</span>
              </li>
            {{/each}}
          </ul>
        {{/if}}

        {{! Article metadata }}
        {{#is settings.article_metadata 'date-end'}}
          <p class="text-gray-600 mt-6">
            {{#is article.created_at article.edited_at}}
              {{date article.created_at timeago=true}}
            {{else}}
              {{t 'updated'}}
              {{date article.edited_at timeago=true}}
            {{/is}}
          </p>
        {{/is}}

      </section>

      {{! Article sharing — moved to article header row 3, kept here as fallback for themes without show_article_sharing }}
      {{! Article navigation }}
      {{~#isnt settings.article_navigation_style 'none'}}
        <div
          class="my-6"
          data-element="article-navigation"
          data-template="article-navigation"
          data-next-title="{{#if settings.use_translations}}{{dc 'next_article'}}{{else}}{{settings.next_article_title}}{{/if}}"
          data-previous-title="{{#if settings.use_translations}}{{dc 'previous_article'}}{{else}}{{settings.previous_article_title}}{{/if}}">
        </div>
      {{/isnt~}}

{{! Jana Article voting - Downvote feedback logic }}
{{#if settings.show_article_voting}}
  {{#with article}}
    <div id="article-voting" class="py-4 my-4 text-center border-top border-bottom">

      <h4 class="font-medium">
        {{t 'was_this_article_helpful'}}
      </h4>

      <div class="button-group mb-4" role="group">
        {{!-- YES / NO buttons generated by Zendesk --}}
        {{vote 'up' class='button button-outline-primary' selected_class='is-active' role='radio'}}
        {{vote 'down' class='button button-outline-primary' selected_class='is-active' role='radio'}}
      </div>

      {{!-- Vote helper label (we hide via CSS later) --}}
      {{vote 'label' class='block text-gray-600 font-size-sm mb-4'}}

      {{#if ../settings.enable_downvote_feedback_modal}}
        {{#unless ../settings.hide_article_downvote_cta}}
          <!-- Downvote feedback (inline, shown below Yes/No buttons) -->
          <div id="downvote-feedback" class="hidden mt-4" aria-hidden="true" data-article-id="{{id}}" data-article-title="{{title}}">
            <textarea
              id="downvote-text"
              class="w-full border p-3 rounded-none"
              rows="4"
              placeholder="Sorry this wasn’t helpful. Please tell us what we can improve."></textarea>

            <div class="mt-3">
              <button id="submit-downvote-feedback" class="button button-primary">Submit Feedback</button>
              <button id="cancel-downvote-feedback" class="button button-outline-primary ml-2">Cancel</button>
            </div>
            <p id="downvote-success" class="text-green-600 mt-3 hidden">
              Thank you! Your feedback has been submitted.
            </p>
            <p id="downvote-error" class="text-red-600 mt-3 hidden" role="alert">
              Sorry, we couldn't submit your feedback. Please try again later.
            </p>
          </div>
        {{/unless}}
      {{/if}}

      {{! Article submit request callout inside voting block }}
      {{#if ../settings.show_article_submit_cta}}
        <p id="article-submit-request-callout" class="mt-4 mb-0">
          <span>Have more questions? </span>
          <a href="{{page_path 'new_request'}}" class="article-submit-request-link" data-requires-auth>
            {{t 'submit_a_request'}}
          </a>
        </p>
      {{/if}}
    </div>
  {{/with}}
{{/if}}
      {{!-- end of article voting --}}

      {{! Recent and related articles }}
      <footer class="row my-6{{#unless settings.show_recently_viewed_articles}}{{#unless settings.show_related_articles}} hidden{{/unless}}{{/unless}}">
        {{#if settings.show_related_articles}}
          {{related_articles}}
        {{/if}}
        {{#if settings.show_recently_viewed_articles}}
          {{recent_articles}}
        {{/if}}
      </footer>

      {{! Article comments }}
      {{#if settings.show_article_comments}}
        <section id="comments" itemscope itemtype="http://schema.org/UserComments">

          {{! Comments header }}
          <header class="border-top border-bottom py-2">
            <h3 class="mt-4">
              {{t 'comments'}}
            </h3>
            <div class="flex justify-content-between align-items-baseline text-gray-600">
              <p>
                {{t 'comments_count' count=article.comment_count}}
              </p>
              {{#if comments}}

                {{! Sorters }}
                <div class="dropdown" x-data="Widgets.dropdown" @click.away="close">
                  <button class="not-a-button py-2 cursor-pointer" aria-haspopup="true" :aria-expanded="isExpanded" x-ref="toggle">
                    {{t 'sort_by'}}
                    <svg class="svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" aria-hidden="true" :class="{ 'rotate-180': isExpanded }">
                      <use xlink:href="#icon-chevron-down" />
                    </svg>
                  </button>
                  <span class="dropdown-menu" role="menu" x-ref="menu" :aria-expanded="isExpanded">
                    {{#each comment_sorters}}
                      <a class="dropdown-item" aria-selected="{{selected}}" href="{{url}}" role="menuitem">
                        {{name}}
                      </a>
                    {{/each}}
                  </span>
                </div>
              {{/if}}
            </div>
          </header>

          {{! Comments list }}
          {{#if comments}}
            <ul class="list-unstyled">
              {{#each comments}}
                <li class="comment py-5 border-bottom" id="{{anchor}}">

                  {{! Comment metadata }}
                  <div class="media mb-4">
                    <div class="avatar">
                      {{#if author.agent}}
                        <svg class="svg-icon absolute bottom-0 right-0 text-primary bg-white border border-white circle" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" aria-hidden="true">
                          <use xlink:href="#icon-agent" />
                        </svg>
                      {{/if}}
                      <img class="avatar-img" src="{{author.avatar_url}}" alt="Comment author">
                    </div>
                    <div class="media-body">
                       <span title="{{author.name}}" id="{{anchor}}-author">
                         {{#link 'user_profile' class="link-implied" id=author.id}}
                           {{author.name}}
                         {{/link}}
                       </span>
                      {{#each author.badges}}
                        {{#is category_slug "titles"}}
                          <span class="badge bg-primary text-primary-inverse py-1 pr-2 mx-2" title="{{description}}" aria-label="{{name}}">
                            {{#if icon_url}}
                              <img src="{{icon_url}}" alt="{{description}}" />
                            {{/if}}
                            {{name}}
                          </span>
                        {{/is}}
                      {{/each}}
                      {{#each author.badges}}
                        {{#is category_slug "achievements"}}
                          {{#if icon_url}}
                            <img width="22" height="22" src="{{icon_url}}" alt="{{name}}" title="{{name}} | {{description}}" aria-label="{{name}}" />
                          {{/if}}
                        {{/is}}
                      {{/each}}
                      <ul class="list-divider">
                        {{#if editor}}
                          <li class="text-gray-600">
                            {{t 'edited'}} {{date edited_at timeago=true}}
                          </li>
                        {{else}}
                          <li class="text-gray-600">
                            {{date created_at timeago=true}}
                          </li>
                        {{/if}}
                      </ul>
                    </div>

                    {{! Comment actions }}
                    <div class="actions-comment">
                      {{#actions}}
                        <svg class="svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" aria-hidden="true">
                          <path fill="none" stroke="currentColor" d="M13.17 3.07l-1.64.71c-.48-.4-1.03-.72-1.63-.94l-.22-1.79a.511.511 0 00-.4-.44C8.86.54 8.44.5 8 .5c-.44 0-.86.04-1.28.11-.22.04-.38.22-.4.44l-.21 1.79c-.6.22-1.15.54-1.63.94l-1.65-.71a.491.491 0 00-.58.13c-.55.65-.99 1.4-1.29 2.21-.08.21 0 .44.18.58l1.45 1.08a4.91 4.91 0 000 1.87l-1.45 1.08c-.18.13-.25.37-.18.58.3.81.74 1.55 1.28 2.2.14.17.38.22.58.13l1.65-.71c.48.4 1.03.72 1.63.94l.21 1.79c.03.22.19.4.4.44.43.07.85.11 1.29.11.44 0 .86-.04 1.28-.11.22-.04.38-.22.4-.44l.21-1.79c.6-.22 1.15-.54 1.63-.94l1.65.71c.2.09.44.04.58-.13.54-.65.98-1.39 1.28-2.2.08-.21 0-.44-.18-.57L13.4 8.95c.07-.32.1-.63.1-.95s-.03-.63-.09-.94l1.45-1.08c.18-.13.25-.37.18-.58-.3-.81-.74-1.55-1.28-2.2a.51.51 0 00-.59-.13z"/>
                          <circle cx="8" cy="8" r="2.5" fill="none" stroke="currentColor"/>
                        </svg>
                      {{/actions}}
                    </div>

                  </div>

                  {{#with ticket}}
                    <a href="{{url}}" target="_zendesk_lotus" class="status-label escalation-badge">
                      {{t 'request'}}{{id}}
                    </a>
                  {{/with}}
                  {{#if pending}}
                    <span class="badge badge-pending">
                      {{t 'pending_approval'}}
                    </span>
                  {{/if}}

                  {{! Comment content }}
                  <section class="content" id="{{anchor}}-body">
                    {{body}}
                  </section>

                  {{! Comment voting }}
                  <div class="button-group button-group-sm" role="group">
                    {{#vote 'up' class='button button-outline-primary' selected_class='is-active' role='radio' aria-describedby=(concat anchor "-author " anchor "-body")}}
                      <svg class="svg-icon rotate-180" xmlns="http://www.w3.org/2000/svg" focusable="false" viewBox="0 0 16 16">
                        <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" d="M4 6.5l3.6 3.6c.2.2.5.2.7 0L12 6.5"></path>
                      </svg>
                    {{/vote}}
                    {{#vote 'down' class='button button-outline-primary' selected_class='is-active' role='radio' aria-describedby=(concat anchor "-author " anchor "-body")}}
                      <svg class="svg-icon" xmlns="http://www.w3.org/2000/svg" focusable="false" viewBox="0 0 16 16">
                        <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" d="M4 6.5l3.6 3.6c.2.2.5.2.7 0L12 6.5"></path>
                      </svg>
                    {{/vote}}
                  </div>
                  {{vote 'sum' class='font-size-sm text-gray-600 ml-1'}}

                </li>
              {{/each}}
            </ul>
          {{/if}}

          {{pagination}}

          {{! Comment form }}
          {{#form 'comment' class='form text-right'}}
            <div class="flex mt-4">
              <div class="avatar">
                {{user_avatar class='avatar-img'}}
              </div>
              <div class="flex-1 form-field">
                {{wysiwyg 'body'}}
              </div>
            </div>
            {{input type='submit'}}
          {{/form}}

          <p class="text-gray-600 mt-4 font-size-md">
            {{comment_callout}}
          </p>

        </section>
      {{/if}}

    </article>

    </article>

    {{! ======================================================= }}
    {{! RIGHT SIDEBAR — Table of Contents                      }}
    {{! ======================================================= }}
    <aside class="article-right-sidebar" aria-label="On this page">
      <div class="article-toc-card" id="article-toc-wrapper">
        <h3 class="article-toc-heading">{{t 'on_this_page'}}</h3>
        <div
          class="article-toc-nav"
          data-element="table-of-contents"
          data-template="sidebar-table-of-contents"
          data-selector=".article-content h2, .article-content h3"
          data-spy="scroll"
          data-offset="{{#if settings.sticky_header}}{{settings.header_height}}{{else}}160px{{/if}}">
        </div>
      </div>
    </aside>

    {{! Call-to-action }}
    {{~#is settings.cta_style 'sidebar'}}
      {{~#isnt settings.cta_location 'home'}}
        <div data-element="template" data-template="call-to-action"></div>
      {{/isnt~}}
    {{/is~}}

  </div>
</div>


{{! Call-to-action }}
{{~#isnt settings.cta_style 'none'}}
  {{~#isnt settings.cta_style 'sidebar'}}
    {{~#isnt settings.cta_location 'home'}}
      <div
        data-element="template"
        data-template="call-to-action">
      </div>
    {{/isnt~}}
  {{/isnt~}}
{{/isnt~}}

<script type="text/javascript">document.documentElement.classList.add('article-page', 'article-' + {{article.id}})</script>
<script>
(function() {
  var el = document.getElementById('article-view-count');
  if (!el) return;
  var id = el.getAttribute('data-article-id');
  if (!id) return;
  fetch('/api/v2/help_center/articles/' + id + '.json')
    .then(function(r){ return r.json(); })
    .then(function(d){ if (d && d.article && typeof d.article.view_count !== 'undefined') { el.textContent = d.article.view_count; } })
    .catch(function(){ el.textContent = '0'; });
})();
</script>
<script>
(function() {
  var dateEls = document.querySelectorAll('.article-meta-date[data-created-at]');
  if (!dateEls.length) return;

  function getOrdinalSuffix(day) {
    if (day >= 11 && day <= 13) return 'th';
    switch (day % 10) {
      case 1: return 'st';
      case 2: return 'nd';
      case 3: return 'rd';
      default: return 'th';
    }
  }

  dateEls.forEach(function(dateEl) {
    var raw = dateEl.getAttribute('data-created-at');
    if (!raw) return;

    var dt = new Date(raw);
    if (isNaN(dt.getTime())) return;

    var day = dt.getDate();
    var dayWithSuffix = day + getOrdinalSuffix(day);
    var month = dt.toLocaleString('en-US', { month: 'long' });
    var year = dt.getFullYear();

    dateEl.textContent = dayWithSuffix + ' ' + month + ' ' + year;
  });
})();
</script>
<script>
(function() {
  var trigger = document.getElementById('article-share-trigger');
  var modal = document.getElementById('article-share-modal');
  var copyBtn = document.getElementById('article-share-copy-link');
  var toast = document.getElementById('share-toast');
  if (!trigger || !modal) return;

  var currentUrl = window.location.href;
  var encodedUrl = encodeURIComponent(currentUrl);
  var shareLinks = {
    facebook: 'https://facebook.com/sharer.php?u=' + encodedUrl,
    linkedin: 'https://www.linkedin.com/sharing/share-offsite/?url=' + encodedUrl,
    twitter: 'https://x.com/intent/tweet?url=' + encodedUrl,
    xing: 'https://www.xing.com/spi/shares/new?url=' + encodedUrl,
    email: 'mailto:?subject=' + encodeURIComponent('Please Review This Information') + '&body=' + encodeURIComponent('I found this on Engineering Centre and think it could be beneficial for you, ' + currentUrl)
  };

  modal.querySelectorAll('[data-share-channel]').forEach(function(link) {
    var channel = link.getAttribute('data-share-channel');
    if (!shareLinks[channel]) return;
    link.setAttribute('href', shareLinks[channel]);
    if (channel === 'email') {
      link.removeAttribute('target');
      link.removeAttribute('rel');
    }
  });

  function openModal() {
    modal.setAttribute('aria-hidden', 'false');
    trigger.setAttribute('aria-expanded', 'true');
    document.documentElement.classList.add('article-share-open');
    var firstAction = modal.querySelector('.article-share-option');
    if (firstAction) firstAction.focus();
  }

  function closeModal() {
    modal.setAttribute('aria-hidden', 'true');
    trigger.setAttribute('aria-expanded', 'false');
    document.documentElement.classList.remove('article-share-open');
    trigger.focus();
  }

  trigger.addEventListener('click', openModal);

  modal.querySelectorAll('[data-share-close]').forEach(function(closeEl) {
    closeEl.addEventListener('click', closeModal);
  });

  modal.querySelectorAll('.article-share-option[data-share-channel]').forEach(function(link) {
    link.addEventListener('click', function() {
      setTimeout(closeModal, 50);
    });
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') {
      closeModal();
    }
  });

  if (copyBtn) {
    copyBtn.addEventListener('click', function() {
      navigator.clipboard.writeText(currentUrl).then(function() {
        if (!toast) return;
        toast.classList.add('show');
        setTimeout(function() { toast.classList.remove('show'); }, 2000);
        closeModal();
      });
    });
  }
})();
</script>
<script>
(function() {
  var votingRoot = document.getElementById('article-voting');
  var feedbackBox = document.getElementById('downvote-feedback');
  var textarea = document.getElementById('downvote-text');
  var submitBtn = document.getElementById('submit-downvote-feedback');
  var cancelBtn = document.getElementById('cancel-downvote-feedback');
  var successEl = document.getElementById('downvote-success');
  var errorEl = document.getElementById('downvote-error');

  if (!votingRoot || !feedbackBox || !textarea || !submitBtn || !cancelBtn) return;

  var voteButtons = votingRoot.querySelectorAll('.button-group .button');
  if (!voteButtons || voteButtons.length < 2) return;

  var upvoteBtn = voteButtons[0];
  var downvoteBtn = voteButtons[1];
  var articleId = feedbackBox.getAttribute('data-article-id') || '';
  var articleTitle = feedbackBox.getAttribute('data-article-title') || 'Article';
  var downvoteFeedbackStorageKey = 'zd_downvote_feedback_submitted';
  var feedbackTicketTags = ['article_feedback', 'downvote_feedback', 'knowledge_center'];

  function getDownvoteFeedbackSubmitted() {
    try {
      return window.localStorage.getItem(downvoteFeedbackStorageKey) === '1';
    } catch (e) {
      return false;
    }
  }

  function setDownvoteFeedbackSubmitted() {
    try {
      window.localStorage.setItem(downvoteFeedbackStorageKey, '1');
    } catch (e) {
      // Ignore storage failures and continue normal UX.
    }
  }

  function setVoteButtonLabels() {
    upvoteBtn.textContent = 'Yes, thanks';
    upvoteBtn.setAttribute('aria-label', 'Yes, thanks');
    downvoteBtn.textContent = 'Not really';
    downvoteBtn.setAttribute('aria-label', 'Not really');
  }

  function hideNotice(el) {
    if (!el) return;
    el.classList.add('hidden');
    el.classList.remove('is-visible', 'is-hiding');
  }

  function showNotice(el) {
    if (!el) return;
    el.classList.remove('hidden', 'is-hiding');
    requestAnimationFrame(function() {
      el.classList.add('is-visible');
    });
  }

  function openFeedback() {
    hideNotice(successEl);
    hideNotice(errorEl);
    feedbackBox.classList.remove('hidden', 'is-hiding');
    feedbackBox.setAttribute('aria-hidden', 'false');
    requestAnimationFrame(function() {
      feedbackBox.classList.add('is-visible');
      textarea.focus();
    });
  }

  function closeFeedback() {
    feedbackBox.classList.remove('is-visible');
    feedbackBox.classList.add('is-hiding');
    feedbackBox.setAttribute('aria-hidden', 'true');
    setTimeout(function() {
      feedbackBox.classList.add('hidden');
      feedbackBox.classList.remove('is-hiding');
      textarea.value = '';
      hideNotice(successEl);
      hideNotice(errorEl);
    }, 200);
  }

  setVoteButtonLabels();

  downvoteBtn.addEventListener('click', function() {
    var wasActive = downvoteBtn.classList.contains('is-active');
    window.setTimeout(function() {
      if (!wasActive) {
        if (getDownvoteFeedbackSubmitted()) {
          closeFeedback();
          return;
        }
        // Was not active and feedback not yet submitted -> show feedback
        openFeedback();
      } else {
        // Was already active -> user is unvoting -> close feedback
        closeFeedback();
      }
    }, 80);
  });

  upvoteBtn.addEventListener('click', closeFeedback);
  cancelBtn.addEventListener('click', closeFeedback);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && feedbackBox.getAttribute('aria-hidden') === 'false') {
      closeFeedback();
    }
  });

  document.addEventListener('mousedown', function(e) {
    if (feedbackBox.getAttribute('aria-hidden') !== 'false') return;
    if (!feedbackBox.contains(e.target)) {
      closeFeedback();
    }
  });

  submitBtn.addEventListener('click', function() {
    var feedbackText = (textarea.value || '').trim();
    hideNotice(successEl);
    hideNotice(errorEl);

    if (feedbackText.length < 3) {
      showNotice(errorEl);
      errorEl.textContent = 'Please enter at least 3 characters before submitting.';
      return;
    }

    submitBtn.disabled = true;

    var payload = {
      request: {
        subject: 'Article downvote feedback: ' + articleTitle,
        tags: feedbackTicketTags,
        comment: {
          body: 'Article ID: ' + articleId + '\nArticle URL: ' + window.location.href + '\n\nFeedback:\n' + feedbackText
        }
      }
    };

    fetch('/api/v2/requests.json', {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(payload)
    })
      .then(function(response) {
        if (!response.ok) throw new Error('Request failed');
        return response.json();
      })
      .then(function() {
        setDownvoteFeedbackSubmitted();
        showNotice(successEl);
        textarea.value = '';
        setTimeout(closeFeedback, 1600);
      })
      .catch(function() {
        errorEl.textContent = "Sorry, we couldn't submit your feedback. Please try again later.";
        showNotice(errorEl);
      })
      .finally(function() {
        submitBtn.disabled = false;
      });
  });
})();
</script>

{{!---------------
   Micro-templates
   ---------------}}

{{! Article navigation }}
{{~#is settings.article_navigation_style 'standard'}}
  <template id="tmpl-article-navigation">
    <% if (previousArticle || nextArticle) { %>
      <div class="row">
        <% if (previousArticle) { %>
          <div class="sm:col">
            <% if (previousTitle) { %>
              <h4 class="mb-2"><%= previousTitle %></h4>
            <% } %>
            <a href="<%= previousArticle.html_url %>"><%= previousArticle.title %></a>
          </div>
        <% } %>
        <% if (nextArticle) { %>
          <div class="sm:col text-right<% if (!previousArticle) { %> sm:col-offset-6<% } %>">
            <% if (nextTitle) { %>
              <h4 class="mb-2"><%= nextTitle %></h4>
            <% } %>
            <a href="<%= nextArticle.html_url %>"><%= nextArticle.title %></a>
          </div>
        <% } %>
      </div>
    <% } %>
  </template>
{{/is~}}

{{! Table of Contents }}
{{~#isnt settings.table_of_contents_style 'none'}}
  {{~#is settings.table_of_contents_style 'simple'}}
    {{! Simple }}
    <script type="text/template" id="tmpl-table-of-contents">
      <% if (allItems.length > 1) { %>
        {{~#if settings.table_of_contents_heading}}
          <h3>
            {{~#if settings.use_translations}}
              {{dc settings.table_of_contents_heading}}
            {{else}}
              {{settings.table_of_contents_heading}}
            {{/if~}}
          </h3>
        {{/if~}}
        <ol class="mb-6 font-size-md">
          <% allItems.forEach(function(item) { %>
            <li class="list-item">
              <a href="<%= item.html_url %>">
                <%= item.name %>
              </a>
              <%= partial('partial-table-of-contents', { items: item.children, partial: partial }) %>
            </li>
          <% }); %>
        </ol>
      <% } %>
    </script>
  {{/is~}}
  {{~#is settings.table_of_contents_style 'boxed'}}
    {{! Boxed }}
    <script type="text/template" id="tmpl-table-of-contents">
      <% if (allItems.length > 1) { %>
        <div class="bg-gray-100 border border-radius px-5 mb-5 float-right w-full md:ml-5 md:px-6 md:col-5 lg:col-6 xl:col-5">
          {{~#if settings.table_of_contents_heading}}
            <h3>
              {{~#if settings.use_translations}}
                {{dc settings.table_of_contents_heading}}
              {{else}}
                {{settings.table_of_contents_heading}}
              {{/if~}}
            </h3>
          {{/if~}}
          <ol class="mb-6 list-unstyled font-size-md">
            <% allItems.forEach(function(item) { %>
              <li class="list-item">
                <a href="<%= item.html_url %>">
                  <%= item.name %>
                </a>
                <%= partial('partial-table-of-contents', { items: item.children, partial: partial }) %>
              </li>
            <% }); %>
          </ol>
        </div>
      <% } %>
    </script>
  {{/is~}}
  {{~#is settings.table_of_contents_style 'full-width'}}
    {{! Full-width }}
    <script type="text/template" id="tmpl-table-of-contents">
      <% if (allItems.length > 1) { %>
        <div class="border border-radius border-left-4 px-6 my-6 w-full">
          {{~#if settings.table_of_contents_heading}}
            <h3>
              {{~#if settings.use_translations}}
                {{dc settings.table_of_contents_heading}}
              {{else}}
                {{settings.table_of_contents_heading}}
              {{/if~}}
            </h3>
          {{/if~}}
          <ol class="mb-6 list-unstyled font-size-md">
            <% allItems.forEach(function(item) { %>
              <li class="list-item">
                <a href="<%= item.html_url %>">
                  <%= item.name %>
                </a>
                <%= partial('partial-table-of-contents', { items: item.children, partial: partial }) %>
              </li>
            <% }); %>
          </ol>
        </div>
      <% } %>
    </script>
  {{/is~}}

  {{~#isnt settings.table_of_contents_style 'simple'}}
    {{~#isnt settings.table_of_contents_style 'boxed'}}
      {{~#isnt settings.table_of_contents_style 'full-width'}}
        {{! Sidebar }}
        <script type="text/template" id="tmpl-sidebar-table-of-contents">
          <% if (allItems.length > 1) { %>
            <div class="sticky top-0{{#unless settings.sticky_header}} pt-4 -mt-4{{/unless}}"{{#if settings.sticky_header}} style="padding-top: {{settings.header_height}}; margin-top: -{{settings.header_height}}; "{{/if}}
              data-spy="scroll"
              data-offset="{{#if settings.sticky_header}}{{settings.header_height}}{{else}}160px{{/if}}">
              <div class="bg-gray-200 py-4 px-5 my-6" x-data="{ active: null }" @scrollspy:active="active = $event.target">
                <h3 class="my-4">
                  {{#if settings.use_translations}}
                    {{dc settings.table_of_contents_heading}}
                  {{else}}
                    {{settings.table_of_contents_heading}}
                  {{/if}}
                </h3>
                <ol x-data="scrollableElement">
                  <% allItems.forEach(function(item, index) { %>
                    <li>
                      <a class="block py-1" :class="{ 'underline font-bold': active === $el }" href="<%= item.html_url %>">
                        <%= item.name %>
                      </a>
                    </li>
                  <% }); %>
                </ol>
              </div>
            </div>
          <% } %>
        </script>
      {{/isnt}}
    {{/isnt}}
  {{/isnt}}

  {{~#isnt settings.table_of_contents_style 'sidebar-left'}}
    {{~#isnt settings.table_of_contents_style 'sidebar-right'}}
      {{! Nested items list }}
      <script type="text/template" id="tmpl-partial-table-of-contents">
        <% if (items.length) { %>
          <ol class="list-none mb-0">
            <% items.forEach(function(item) { %>
              <li class="list-item">
                <a href="<%= item.html_url %>">
                  <%= item.name %>
                </a>
                <%= partial('partial-table-of-contents', { items: item.children, partial: partial }) %>
              </li>
            <% }); %>
          </ol>
        <% } %>
      </script>
    {{/isnt}}
  {{/isnt}}
{{/isnt}}

