{{! ---------------------------------------------------------
   UNIVERSAL BREADCRUMBS – FINAL VERSION (CLICKABLE HOME)
   Updated by: Kalidas, Janardhanan
   Date: 20‑Mar‑2026

   Purpose:
   - Make "Home" clickable using help_center.url
   - Add home icon via CSS
   - Display native breadcrumbs beside Home
   - Work safely in ALL templates (home, category, section, article)
---------------------------------------------------------- }}

<div class="bg-gray-100 pt-5 pb-1">
  <div class="container">

    <div class="breadcrumbs-wrapper">

      {{!-- CLICKABLE HOME BREADCRUMB --}}
      <a href="{{help_center.url}}" class="bc-home">Home</a>

      {{!-- Native Zendesk breadcrumbs (must remain untouched) --}}
      <div class="bc-native">
        {{breadcrumbs}}
      </div>

    </div>

  </div>
</div>
<div class="container" id="page-container">
  <div class="article-3col-layout">

    {{! ======================================================= }}
    {{! LEFT SIDEBAR — Articles in this section                 }}
    {{! ======================================================= }}
    <aside class="article-left-sidebar" aria-label="Articles in this section">
      {{#isnt settings.article_sidebar 'none'}}
        {{#is settings.article_sidebar 'articles-in-section'}}
          <div class="article-sidebar-card">
            <h3 class="article-sidebar-heading">{{t 'articles_in_section'}}</h3>
            <ul class="article-sidebar-list">
              {{#each section.articles}}
                <li>
                  <a class="article-sidebar-link{{#is id ../article.id}} is-active{{/is}}" href="{{url}}">
                    {{title}}
                  </a>
                </li>
              {{/each}}
            </ul>
            <p class="article-sidebar-more">
              <a href="{{section.url}}">Show all articles</a>
            </p>
          </div>
        {{else}}
          <div data-element="navigation" data-template="{{settings.article_sidebar}}"></div>
        {{/is}}
      {{/isnt}}
    </aside>

    {{! ======================================================= }}
    {{! CENTER — Article content                               }}
    {{! ======================================================= }}
    <article class="article-main-content" itemscope itemtype="http://schema.org/Article">

      {{! Article header }}
      <div class="article-title py-4">
        <h1 title="{{article.title}}" itemprop="name">
          {{article.title}}
          {{#if article.internal}}
            <svg class="svg-icon text-base font-size-xl ml-1 mb-1" xmlns="http://www.w3.org/2000/svg" focusable="false" viewBox="0 0 16 16">
              <title>{{t 'internal'}}</title>
              <rect width="12" height="9" x="2" y="7" fill="currentColor" rx="1" ry="1"/>
              <path fill="none" stroke="currentColor" d="M4.5 7.5V4a3.5 3.5 0 017 0v3.5"/>
            </svg>
          {{/if}}
        </h1>

        {{! Row 1: Author | Date | Follow }}
        <div class="article-meta-row">
          {{#is settings.article_metadata 'author'}}
            <span class="article-meta-author">
              {{#link 'user_profile' class="article-author-link" id=article.author.id}}
                {{article.author.name}}
              {{/link}}
            </span>
            <span class="article-meta-sep">|</span>
          {{/is}}
          {{#isnt settings.article_metadata 'none'}}
            <span class="article-meta-date">
              {{#is article.created_at article.edited_at}}
                {{date article.created_at timeago=true}}
              {{else}}
                {{t 'updated'}} {{date article.edited_at timeago=true}}
              {{/is}}
            </span>
          {{/isnt}}
          {{#if settings.show_follow_article}}
            <span class="article-meta-follow">
              {{subscribe}}
            </span>
          {{/if}}
        </div>

        {{! Row 2: Content tags }}
        {{#if (compare article.content_tags.length ">" 0)}}
          <ul class="article-tags-custom">
            {{#each article.content_tags}}
              <li>
                {{#link "search_result" content_tag_id=id class="article-tag-link"}}
                  {{name}}
                {{/link}}
              </li>
            {{/each}}
          </ul>
        {{/if}}

        {{! Row 3: Views | Likes | Share }}
        <div class="article-actions-row">
          {{! Views — populated via API }}
          <span class="article-action-item article-action-views" title="Article views">
            <img src="{{asset 'views.svg'}}" width="16" height="16" alt="" aria-hidden="true">
            <span class="article-action-count" id="article-view-count" data-article-id="{{article.id}}">0</span>
          </span>
          {{! Likes }}
          <span class="article-action-item article-action-likes" title="Helpful votes">
            <img src="{{asset 'thumb_up.svg'}}" width="16" height="16" alt="" aria-hidden="true">
            <span class="article-action-count">{{article.vote_sum}}</span>
          </span>
          {{! Share — right-aligned }}
          <button class="article-action-share" onclick="navigator.clipboard.writeText(window.location.href).then(function(){var b=document.getElementById('share-toast');b.classList.add('show');setTimeout(function(){b.classList.remove('show')},2000)})" title="Copy link" aria-label="Copy article link">
            <img src="{{asset 'share.svg'}}" width="16" height="16" alt="" aria-hidden="true">
            <span>Share</span>
          </button>
          <span id="share-toast" class="article-share-toast">Link copied!</span>
        </div>

      </div>

      {{! Article content }}
      <section class="content article-content mb-6" itemprop="articleBody">

        {{! Table of Contents }}
        {{~#isnt settings.table_of_contents_style 'none'}}
          {{~#isnt settings.table_of_contents_style 'sidebar-left'}}
            {{~#isnt settings.table_of_contents_style 'sidebar-right'}}
              <div
                class="table-of-contents"
                data-element="table-of-contents"
                data-template="table-of-contents"
                data-selector=".content h2">
              </div>
            {{/isnt~}}
          {{/isnt~}}
        {{/isnt~}}

        {{! Article content }}
        {{article.body}}

        {{! Attachments }}
        {{#if attachments}}
          <ul class="list-unstyled my-6">
            {{#each attachments}}
              <li class="list-item">
                <svg class="svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" aria-hidden="true">
                  <path fill="none" stroke="currentColor" stroke-linecap="round" d="M9.5 4v7.7c0 .8-.7 1.5-1.5 1.5s-1.5-.7-1.5-1.5V3C6.5 1.6 7.6.5 9 .5s2.5 1.1 2.5 2.5v9c0 1.9-1.6 3.5-3.5 3.5S4.5 13.9 4.5 12V4"/>
                </svg>
                <a class="mr-2" href="{{url}}" target="_blank">{{name}}</a><span class="font-size-md text-gray-600">{{size}}</span>
              </li>
            {{/each}}
          </ul>
        {{/if}}

        {{! Article metadata }}
        {{#is settings.article_metadata 'date-end'}}
          <p class="text-gray-600 mt-6">
            {{#is article.created_at article.edited_at}}
              {{date article.created_at timeago=true}}
            {{else}}
              {{t 'updated'}}
              {{date article.edited_at timeago=true}}
            {{/is}}
          </p>
        {{/is}}

      </section>

      {{! Article sharing — moved to article header row 3, kept here as fallback for themes without show_article_sharing }}
      {{! Article navigation }}
      {{~#isnt settings.article_navigation_style 'none'}}
        <div
          class="my-6"
          data-element="article-navigation"
          data-template="article-navigation"
          data-next-title="{{#if settings.use_translations}}{{dc 'next_article'}}{{else}}{{settings.next_article_title}}{{/if}}"
          data-previous-title="{{#if settings.use_translations}}{{dc 'previous_article'}}{{else}}{{settings.previous_article_title}}{{/if}}">
        </div>
      {{/isnt~}}

{{! Jana Article voting - Downvote feedback logic }}
{{#if settings.show_article_voting}}
  {{#with article}}
    <div id="article-voting" class="py-4 my-4 text-center border-top border-bottom">

      <h4 class="font-medium">
        {{t 'was_this_article_helpful'}}
      </h4>

      <div class="button-group mb-4" role="group">
        {{!-- YES / NO buttons generated by Zendesk --}}
        {{vote 'up' class='button button-outline-primary' selected_class='is-active' role='radio'}}
        {{vote 'down' class='button button-outline-primary' selected_class='is-active' role='radio'}}
      </div>

      {{!-- Vote helper label (we hide via CSS later) --}}
      {{vote 'label' class='block text-gray-600 font-size-sm mb-4'}}

      {{#unless ../settings.hide_article_downvote_cta}}
        <p class="my-5">
          {{../request_callout}}
        </p>

        <!-- Custom downvote feedback modal (initially hidden) -->
        <div id="downvote-feedback" class="hidden mt-4" aria-hidden="true">
          <textarea
            id="downvote-text"
            class="w-full border p-3 rounded-none"
            rows="4"
            placeholder="Sorry this wasn’t helpful. Please tell us what we can improve."></textarea>

          <div class="mt-3">
            <button id="submit-downvote-feedback" class="button button-primary">Submit Feedback</button>
            <button id="cancel-downvote-feedback" class="button button-outline-primary ml-2">Cancel</button>
          </div>

          <p id="downvote-success" class="text-green-600 mt-3 hidden">
            Thank you! Your feedback has been submitted.
          </p>
          <p id="downvote-error" class="text-red-600 mt-3 hidden" role="alert">
            Sorry, we couldn't submit your feedback. Please try again later.
          </p>
        </div>
      {{/unless}}
    </div>
  {{/with}}
{{/if}}
      {{!-- end of article voting --}}

      {{#if settings.show_article_submit_request_cta}}
        <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 my-8 text-center">
          <h3 class="h3 mb-3">{{t 'submit_a_request'}}</h3>
          <a class="button button-primary" href="{{page_path 'new_request'}}" data-requires-auth>
            {{t 'submit_a_request'}}
          </a>
        </div>
      {{/if}}
      

      {{! Recent and related articles }}
      <footer class="row my-6{{#unless settings.show_recently_viewed_articles}}{{#unless settings.show_related_articles}} hidden{{/unless}}{{/unless}}">
        {{#if settings.show_related_articles}}
          {{related_articles}}
        {{/if}}
        {{#if settings.show_recently_viewed_articles}}
          {{recent_articles}}
        {{/if}}
      </footer>

      {{! Article comments }}
      {{#if settings.show_article_comments}}
        <section id="comments" itemscope itemtype="http://schema.org/UserComments">

          {{! Comments header }}
          <header class="border-top border-bottom py-2">
            <h3 class="mt-4">
              {{t 'comments'}}
            </h3>
            <div class="flex justify-content-between align-items-baseline text-gray-600">
              <p>
                {{t 'comments_count' count=article.comment_count}}
              </p>
              {{#if comments}}

                {{! Sorters }}
                <div class="dropdown" x-data="Widgets.dropdown" @click.away="close">
                  <button class="not-a-button py-2 cursor-pointer" aria-haspopup="true" :aria-expanded="isExpanded" x-ref="toggle">
                    {{t 'sort_by'}}
                    <svg class="svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" aria-hidden="true" :class="{ 'rotate-180': isExpanded }">
                      <use xlink:href="#icon-chevron-down" />
                    </svg>
                  </button>
                  <span class="dropdown-menu" role="menu" x-ref="menu" :aria-expanded="isExpanded">
                    {{#each comment_sorters}}
                      <a class="dropdown-item" aria-selected="{{selected}}" href="{{url}}" role="menuitem">
                        {{name}}
                      </a>
                    {{/each}}
                  </span>
                </div>
              {{/if}}
            </div>
          </header>

          {{! Comments list }}
          {{#if comments}}
            <ul class="list-unstyled">
              {{#each comments}}
                <li class="comment py-5 border-bottom" id="{{anchor}}">

                  {{! Comment metadata }}
                  <div class="media mb-4">
                    <div class="avatar">
                      {{#if author.agent}}
                        <svg class="svg-icon absolute bottom-0 right-0 text-primary bg-white border border-white circle" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" aria-hidden="true">
                          <use xlink:href="#icon-agent" />
                        </svg>
                      {{/if}}
                      <img class="avatar-img" src="{{author.avatar_url}}" alt="Comment author">
                    </div>
                    <div class="media-body">
                       <span title="{{author.name}}" id="{{anchor}}-author">
                         {{#link 'user_profile' class="link-implied" id=author.id}}
                           {{author.name}}
                         {{/link}}
                       </span>
                      {{#each author.badges}}
                        {{#is category_slug "titles"}}
                          <span class="badge bg-primary text-primary-inverse py-1 pr-2 mx-2" title="{{description}}" aria-label="{{name}}">
                            {{#if icon_url}}
                              <img src="{{icon_url}}" alt="{{description}}" />
                            {{/if}}
                            {{name}}
                          </span>
                        {{/is}}
                      {{/each}}
                      {{#each author.badges}}
                        {{#is category_slug "achievements"}}
                          {{#if icon_url}}
                            <img width="22" height="22" src="{{icon_url}}" alt="{{name}}" title="{{name}} | {{description}}" aria-label="{{name}}" />
                          {{/if}}
                        {{/is}}
                      {{/each}}
                      <ul class="list-divider">
                        {{#if editor}}
                          <li class="text-gray-600">
                            {{t 'edited'}} {{date edited_at timeago=true}}
                          </li>
                        {{else}}
                          <li class="text-gray-600">
                            {{date created_at timeago=true}}
                          </li>
                        {{/if}}
                      </ul>
                    </div>

                    {{! Comment actions }}
                    <div class="actions-comment">
                      {{#actions}}
                        <svg class="svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" aria-hidden="true">
                          <path fill="none" stroke="currentColor" d="M13.17 3.07l-1.64.71c-.48-.4-1.03-.72-1.63-.94l-.22-1.79a.511.511 0 00-.4-.44C8.86.54 8.44.5 8 .5c-.44 0-.86.04-1.28.11-.22.04-.38.22-.4.44l-.21 1.79c-.6.22-1.15.54-1.63.94l-1.65-.71a.491.491 0 00-.58.13c-.55.65-.99 1.4-1.29 2.21-.08.21 0 .44.18.58l1.45 1.08a4.91 4.91 0 000 1.87l-1.45 1.08c-.18.13-.25.37-.18.58.3.81.74 1.55 1.28 2.2.14.17.38.22.58.13l1.65-.71c.48.4 1.03.72 1.63.94l.21 1.79c.03.22.19.4.4.44.43.07.85.11 1.29.11.44 0 .86-.04 1.28-.11.22-.04.38-.22.4-.44l.21-1.79c.6-.22 1.15-.54 1.63-.94l1.65.71c.2.09.44.04.58-.13.54-.65.98-1.39 1.28-2.2.08-.21 0-.44-.18-.57L13.4 8.95c.07-.32.1-.63.1-.95s-.03-.63-.09-.94l1.45-1.08c.18-.13.25-.37.18-.58-.3-.81-.74-1.55-1.28-2.2a.51.51 0 00-.59-.13z"/>
                          <circle cx="8" cy="8" r="2.5" fill="none" stroke="currentColor"/>
                        </svg>
                      {{/actions}}
                    </div>

                  </div>

                  {{#with ticket}}
                    <a href="{{url}}" target="_zendesk_lotus" class="status-label escalation-badge">
                      {{t 'request'}}{{id}}
                    </a>
                  {{/with}}
                  {{#if pending}}
                    <span class="badge badge-pending">
                      {{t 'pending_approval'}}
                    </span>
                  {{/if}}

                  {{! Comment content }}
                  <section class="content" id="{{anchor}}-body">
                    {{body}}
                  </section>

                  {{! Comment voting }}
                  <div class="button-group button-group-sm" role="group">
                    {{#vote 'up' class='button button-outline-primary' selected_class='is-active' role='radio' aria-describedby=(concat anchor "-author " anchor "-body")}}
                      <svg class="svg-icon rotate-180" xmlns="http://www.w3.org/2000/svg" focusable="false" viewBox="0 0 16 16">
                        <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" d="M4 6.5l3.6 3.6c.2.2.5.2.7 0L12 6.5"></path>
                      </svg>
                    {{/vote}}
                    {{#vote 'down' class='button button-outline-primary' selected_class='is-active' role='radio' aria-describedby=(concat anchor "-author " anchor "-body")}}
                      <svg class="svg-icon" xmlns="http://www.w3.org/2000/svg" focusable="false" viewBox="0 0 16 16">
                        <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" d="M4 6.5l3.6 3.6c.2.2.5.2.7 0L12 6.5"></path>
                      </svg>
                    {{/vote}}
                  </div>
                  {{vote 'sum' class='font-size-sm text-gray-600 ml-1'}}

                </li>
              {{/each}}
            </ul>
          {{/if}}

          {{pagination}}

          {{! Comment form }}
          {{#form 'comment' class='form text-right'}}
            <div class="flex mt-4">
              <div class="avatar">
                {{user_avatar class='avatar-img'}}
              </div>
              <div class="flex-1 form-field">
                {{wysiwyg 'body'}}
              </div>
            </div>
            {{input type='submit'}}
          {{/form}}

          <p class="text-gray-600 mt-4 font-size-md">
            {{comment_callout}}
          </p>

        </section>
      {{/if}}

    </article>

    </article>

    {{! ======================================================= }}
    {{! RIGHT SIDEBAR — Table of Contents                      }}
    {{! ======================================================= }}
    <aside class="article-right-sidebar" aria-label="On this page">
      <div class="article-toc-card" id="article-toc-wrapper">
        <h3 class="article-toc-heading">{{t 'on_this_page'}}</h3>
        <div
          class="article-toc-nav"
          data-element="table-of-contents"
          data-template="sidebar-table-of-contents"
          data-selector=".article-content h2, .article-content h3"
          data-spy="scroll"
          data-offset="{{#if settings.sticky_header}}{{settings.header_height}}{{else}}160px{{/if}}">
        </div>
      </div>
    </aside>

    {{! Call-to-action }}
    {{~#is settings.cta_style 'sidebar'}}
      {{~#isnt settings.cta_location 'home'}}
        <div data-element="template" data-template="call-to-action"></div>
      {{/isnt~}}
    {{/is~}}

  </div>
</div>


{{! Call-to-action }}
{{~#isnt settings.cta_style 'none'}}
  {{~#isnt settings.cta_style 'sidebar'}}
    {{~#isnt settings.cta_location 'home'}}
      <div
        data-element="template"
        data-template="call-to-action">
      </div>
    {{/isnt~}}
  {{/isnt~}}
{{/isnt~}}

<script type="text/javascript">document.documentElement.classList.add('article-page', 'article-' + {{article.id}})</script>
<script>
(function() {
  var el = document.getElementById('article-view-count');
  if (!el) return;
  var id = el.getAttribute('data-article-id');
  if (!id) return;
  fetch('/api/v2/help_center/articles/' + id + '.json')
    .then(function(r){ return r.json(); })
    .then(function(d){ if (d && d.article && typeof d.article.view_count !== 'undefined') { el.textContent = d.article.view_count; } })
    .catch(function(){ el.textContent = '0'; });
})();
</script>

{{!---------------
   Micro-templates
   ---------------}}

{{! Article navigation }}
{{~#is settings.article_navigation_style 'standard'}}
  <template id="tmpl-article-navigation">
    <% if (previousArticle || nextArticle) { %>
      <div class="row">
        <% if (previousArticle) { %>
          <div class="sm:col">
            <% if (previousTitle) { %>
              <h4 class="mb-2"><%= previousTitle %></h4>
            <% } %>
            <a href="<%= previousArticle.html_url %>"><%= previousArticle.title %></a>
          </div>
        <% } %>
        <% if (nextArticle) { %>
          <div class="sm:col text-right<% if (!previousArticle) { %> sm:col-offset-6<% } %>">
            <% if (nextTitle) { %>
              <h4 class="mb-2"><%= nextTitle %></h4>
            <% } %>
            <a href="<%= nextArticle.html_url %>"><%= nextArticle.title %></a>
          </div>
        <% } %>
      </div>
    <% } %>
  </template>
{{/is~}}

{{! Table of Contents }}
{{~#isnt settings.table_of_contents_style 'none'}}
  {{~#is settings.table_of_contents_style 'simple'}}
    {{! Simple }}
    <script type="text/template" id="tmpl-table-of-contents">
      <% if (allItems.length > 1) { %>
        {{~#if settings.table_of_contents_heading}}
          <h3>
            {{~#if settings.use_translations}}
              {{dc settings.table_of_contents_heading}}
            {{else}}
              {{settings.table_of_contents_heading}}
            {{/if~}}
          </h3>
        {{/if~}}
        <ol class="mb-6 font-size-md">
          <% allItems.forEach(function(item) { %>
            <li class="list-item">
              <a href="<%= item.html_url %>">
                <%= item.name %>
              </a>
              <%= partial('partial-table-of-contents', { items: item.children, partial: partial }) %>
            </li>
          <% }); %>
        </ol>
      <% } %>
    </script>
  {{/is~}}
  {{~#is settings.table_of_contents_style 'boxed'}}
    {{! Boxed }}
    <script type="text/template" id="tmpl-table-of-contents">
      <% if (allItems.length > 1) { %>
        <div class="bg-gray-100 border border-radius px-5 mb-5 float-right w-full md:ml-5 md:px-6 md:col-5 lg:col-6 xl:col-5">
          {{~#if settings.table_of_contents_heading}}
            <h3>
              {{~#if settings.use_translations}}
                {{dc settings.table_of_contents_heading}}
              {{else}}
                {{settings.table_of_contents_heading}}
              {{/if~}}
            </h3>
          {{/if~}}
          <ol class="mb-6 list-unstyled font-size-md">
            <% allItems.forEach(function(item) { %>
              <li class="list-item">
                <a href="<%= item.html_url %>">
                  <%= item.name %>
                </a>
                <%= partial('partial-table-of-contents', { items: item.children, partial: partial }) %>
              </li>
            <% }); %>
          </ol>
        </div>
      <% } %>
    </script>
  {{/is~}}
  {{~#is settings.table_of_contents_style 'full-width'}}
    {{! Full-width }}
    <script type="text/template" id="tmpl-table-of-contents">
      <% if (allItems.length > 1) { %>
        <div class="border border-radius border-left-4 px-6 my-6 w-full">
          {{~#if settings.table_of_contents_heading}}
            <h3>
              {{~#if settings.use_translations}}
                {{dc settings.table_of_contents_heading}}
              {{else}}
                {{settings.table_of_contents_heading}}
              {{/if~}}
            </h3>
          {{/if~}}
          <ol class="mb-6 list-unstyled font-size-md">
            <% allItems.forEach(function(item) { %>
              <li class="list-item">
                <a href="<%= item.html_url %>">
                  <%= item.name %>
                </a>
                <%= partial('partial-table-of-contents', { items: item.children, partial: partial }) %>
              </li>
            <% }); %>
          </ol>
        </div>
      <% } %>
    </script>
  {{/is~}}

  {{~#isnt settings.table_of_contents_style 'simple'}}
    {{~#isnt settings.table_of_contents_style 'boxed'}}
      {{~#isnt settings.table_of_contents_style 'full-width'}}
        {{! Sidebar }}
        <script type="text/template" id="tmpl-sidebar-table-of-contents">
          <% if (allItems.length > 1) { %>
            <div class="sticky top-0{{#unless settings.sticky_header}} pt-4 -mt-4{{/unless}}"{{#if settings.sticky_header}} style="padding-top: {{settings.header_height}}; margin-top: -{{settings.header_height}}; "{{/if}}
              data-spy="scroll"
              data-offset="{{#if settings.sticky_header}}{{settings.header_height}}{{else}}160px{{/if}}">
              <div class="bg-gray-200 py-4 px-5 my-6" x-data="{ active: null }" @scrollspy:active="active = $event.target">
                <h3 class="my-4">
                  {{#if settings.use_translations}}
                    {{dc settings.table_of_contents_heading}}
                  {{else}}
                    {{settings.table_of_contents_heading}}
                  {{/if}}
                </h3>
                <ol x-data="scrollableElement">
                  <% allItems.forEach(function(item, index) { %>
                    <li>
                      <a class="block py-1" :class="{ 'underline font-bold': active === $el }" href="<%= item.html_url %>">
                        <%= item.name %>
                      </a>
                    </li>
                  <% }); %>
                </ol>
              </div>
            </div>
          <% } %>
        </script>
      {{/isnt}}
    {{/isnt}}
  {{/isnt}}

  {{~#isnt settings.table_of_contents_style 'sidebar-left'}}
    {{~#isnt settings.table_of_contents_style 'sidebar-right'}}
      {{! Nested items list }}
      <script type="text/template" id="tmpl-partial-table-of-contents">
        <% if (items.length) { %>
          <ol class="list-none mb-0">
            <% items.forEach(function(item) { %>
              <li class="list-item">
                <a href="<%= item.html_url %>">
                  <%= item.name %>
                </a>
                <%= partial('partial-table-of-contents', { items: item.children, partial: partial }) %>
              </li>
            <% }); %>
          </ol>
        <% } %>
      </script>
    {{/isnt}}
  {{/isnt}}
{{/isnt}}

{{! Maybe hide Table of Contents based on article label }}
{{~#each (filter article.labels on="identifier" equals="no_toc")}}
  <style>
    .table-of-contents {
      display: none !important;
    }
  </style>
{{/each~}}

{{! Content tag data }}
{{#if (compare article.content_tags.length ">" 0)}}
  <script type="text/javascript">
    Theme = window.Theme || {};
    Theme.contentTags = [{{~#each article.content_tags}}{ id: {{json_stringify id}}, name: {{json_stringify name}} }{{#unless @last}},{{/unless}}{{/each~}}];
  </script>
{{/if}}