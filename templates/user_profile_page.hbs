{{! User profile page }}
<div class="bg-gray-100 user-profile-shell">
  <div class="container py-5" id="page-container">
    <div class="profile-layout">

      <aside class="profile-sidebar" aria-label="Profile navigation">
        <section class="card card-body bg-white profile-card">
          <div class="avatar avatar-lg profile-sidebar-avatar font-size-lg">
            {{#if user.agent}}
              <svg class="svg-icon absolute bottom-0 right-0 text-primary bg-white border border-white circle" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" aria-hidden="true">
                <use xlink:href="#icon-agent" />
              </svg>
            {{/if}}
            <img class="avatar-img" src="{{user.avatar_url}}" alt="{{user.name}}">
          </div>

          <h2 class="profile-sidebar-name">
            {{user.name}}
          </h2>

          <div class="profile-sidebar-nav-wrap">
            <nav class="profile-sidebar-nav" aria-label="Account menu">
              <a class="profile-nav-link" href="{{page_path 'help_center'}}">Home</a>
              {{#link 'contributions' class='profile-nav-link'}}{{t 'activities'}}{{/link}}
              {{link 'requests' class='profile-nav-link'}}
              {{#if user.url}}
                <a class="profile-nav-link is-active" aria-current="page" href="{{user.url}}">{{t 'profile'}}</a>
              {{else}}
                <span class="profile-nav-link is-active" aria-current="page">{{t 'profile'}}</span>
              {{/if}}
            </nav>
          </div>
        </section>
      </aside>

      <main class="profile-main">
        <header class="profile-main-header">
          <h1>Account Settings</h1>
        </header>

        <section class="card card-body bg-white profile-card" aria-labelledby="my-profile-title">
          <header class="profile-card-header">
            <h2 class="profile-card-title" id="my-profile-title">My Profile</h2>
            <div class="profile-card-actions">
              {{actions class='actions-user white-space-no-wrap my-1'}}
            </div>
          </header>

          <div class="profile-summary-row">
            <div class="avatar avatar-lg mr-4 font-size-lg">
              {{#if user.agent}}
                <svg class="svg-icon absolute bottom-0 right-0 text-primary bg-white border border-white circle" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" aria-hidden="true">
                  <use xlink:href="#icon-agent" />
                </svg>
              {{/if}}
              <img class="avatar-img" src="{{user.avatar_url}}" alt="{{user.name}}">
            </div>
            <div class="profile-summary-content">
              <h3 class="mt-0 mb-1">
                {{#if user.url}}
                  <a href="{{user.url}}" target="_zendesk_lotus" title="{{t 'open_user_in_support'}}">
                    {{user.name}}
                  </a>
                {{else}}
                  {{user.name}}
                {{/if}}
              </h3>
              <p class="text-gray-600 mb-2">
                {{#if description}}
                  {{description}}
                {{else}}
                  {{t 'no_activity_yet'}}
                {{/if}}
              </p>
              <div class="flex flex-wrap">
                {{#each user.badges}}
                  {{#is category_slug "titles"}}
                    <span class="badge bg-primary text-primary-inverse align-middle py-1 pr-2 mr-2 mb-2" title="{{description}}" aria-label="{{name}}">
                      {{#if icon_url}}
                        <img src="{{icon_url}}" alt="{{description}}" />
                      {{/if}}
                      {{name}}
                    </span>
                  {{/is}}
                {{/each}}
              </div>
            </div>
          </div>

          <div class="profile-helper-actions">
            {{#if private_profile}}
              <span class="badge py-2 px-4 my-1">
                {{t 'private'}}
                <svg class="svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" aria-hidden="true">
                  <path fill="none" stroke="currentColor" d="M3.5 5.5V3a2.5 2.5 0 015 0v2.5"/>
                  <rect width="10" height="7" x="1" y="5" fill="currentColor" rx="1" ry="1"/>
                </svg>
              </span>
            {{/if}}
          </div>
        </section>

        <section class="card card-body bg-white profile-card" aria-labelledby="personal-information-title">
          <header class="profile-card-header">
            <h2 class="profile-card-title" id="personal-information-title">Personal Information</h2>
          </header>

          <dl class="profile-field-grid">
            <div class="profile-field-item">
              <dt>Name</dt>
              <dd>{{user.name}}</dd>
            </div>
            <div class="profile-field-item">
              <dt>{{t 'member_since'}}</dt>
              <dd>
                {{#if member_since}}
                  {{date member_since format='medium'}}
                {{else}}
                  {{t 'no_activity_yet'}}
                {{/if}}
              </dd>
            </div>
            <div class="profile-field-item">
              <dt>{{t 'last_activity'}}</dt>
              <dd>
                {{#if last_activity_at}}
                  {{date last_activity_at timeago=true}}
                {{else}}
                  {{t 'no_activity_yet'}}
                {{/if}}
              </dd>
            </div>
            <div class="profile-field-item">
              <dt>{{t 'subscriptions'}}</dt>
              <dd>{{subscription_count}}</dd>
            </div>
            {{#if description}}
              <div class="profile-field-item">
                <dt>Intro</dt>
                <dd>{{description}}</dd>
              </div>
            {{/if}}
          </dl>

          <div class="profile-achievements">
            {{#each user.badges}}
              {{#is category_slug "achievements"}}
                {{#if icon_url}}
                  <img class="h-5 w-5 mr-1" src="{{icon_url}}" alt="{{name}}" title="{{name}} | {{description}}" aria-label="{{name}}" />
                {{/if}}
              {{/is}}
            {{/each}}
          </div>

          {{#if description}}
            <p class="profile-description mb-0">
              {{description}}
            </p>
          {{/if}}
        </section>

        {{#if visible}}
          {{#if member_since}}
            <section class="card bg-white profile-card profile-activity-card">
              <header class="profile-activity-header">
                <h2 class="profile-card-title mb-0">{{t 'activities'}}</h2>
                <p class="profile-activity-metric mb-0">Article Votes: {{vote_count}}</p>
              </header>

              <nav class="nav navbar-light nav-line collapsible-nav mb-0 font-size-md profile-filter-nav" aria-label="Profile filters">
                {{#each filters}}
                  {{#if selected}}
                    <a class="nav-link py-4{{#unless @last}} md:mr-4{{/unless}} is-active" aria-current="page" aria-selected="true" href="{{url}}">
                      {{name}}
                    </a>
                  {{else}}
                    <a class="nav-link py-4{{#unless @last}} md:mr-4{{/unless}}" aria-selected="false" href="{{url}}">
                      {{name}}
                    </a>
                  {{/if}}
                {{/each}}
              </nav>

              <div class="profile-tab-panel">
                {{! Activity overview }}
                {{#is current_filter.identifier 'activities'}}
                  {{#if activities}}
                    <header class="pt-4 pb-2">
                      <h3 class="mb-1">
                        {{t 'activity_overview'}}
                      </h3>
                      <div class="md:flex justify-content-between align-items-baseline text-gray-600">
                        <p class="py-2 mb-2 text-gray-600">
                          {{t 'latest_activity' name=user.name}}
                        </p>
                      </div>
                    </header>

                    {{! Activities list }}
                    <ul class="list-unstyled">
                      {{#each activities}}
                        <li class="relative pb-5 md:pl-5{{#unless @last}} md:border-left{{/unless}}">
                          <div class="py-3 align-items-center {{contribution.object_type}}">
                            <div class="top-0 left-0 z-10 bg-white circle pr-1 md:absolute md:p-4 md:-ml-5">
                              <svg class="svg-icon flex bottom-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" aria-hidden="true">
                                {{#contains type "article"}}
                                  <path fill="none" stroke="currentColor" stroke-linecap="round" d="M3.5 5.5h5m-5 2h5m-5 2h5m2-6.29V11c0 .28-.22.5-.5.5H2c-.28 0-.5-.22-.5-.5V1c0-.28.22-.5.5-.5h5.79c.13 0 .26.05.35.15l2.21 2.21c.1.09.15.21.15.35zM7.5.5V3c0 .28.22.5.5.5h2.5"/>
                                {{/contains}}
                                {{#contains type "post"}}
                                  <path fill="none" stroke="currentColor" stroke-linecap="round" d="M1.5 6.5H1C.7 6.5.5 6.3.5 6V1C.5.7.7.5 1 .5h7c.3 0 .5.2.5.5v2.5m-6-1h4m-1 5h4m-4 2h4M4 5.5h7c.3 0 .5.2.5.5v5c0 .3-.2.5-.5.5H4c-.3 0-.5-.2-.5-.5V6c0-.3.2-.5.5-.5z"/>
                                {{/contains}}
                                {{#contains type "comment"}}
                                  <path fill="none" stroke="currentColor" d="M1 .5h10c.3 0 .5.2.5.5v7c0 .3-.2.5-.5.5H6l-2.6 2.6c-.3.3-.9.1-.9-.4V8.5H1C.7 8.5.5 8.3.5 8V1C.5.7.7.5 1 .5z"/>
                                {{/contains}}
                              </svg>
                            </div>
                            {{label}}
                          </div>
                          <div class="p-5 bg-gray-100 border-radius">
                            {{#with contribution}}
                              {{#is object_type 'comment'}}
                                <nav aria-label="Activity location">
                                  <ol class="breadcrumbs">
                                    {{#each path_steps}}
                                      <li title="{{name}}">
                                        <a href="{{url}}">
                                          {{name}}
                                        </a>
                                      </li>
                                    {{/each}}
                                  </ol>
                                </nav>
                              {{else}}
                                <h3 class="h4 mt-0">
                                  <a href="{{url}}">
                                    {{title}}
                                  </a>
                                </h3>
                              {{/is}}
                              <p>
                                {{excerpt body characters=200}}
                              </p>

                              {{! Activity metadata }}
                              <ul class="list-divider mb-0">
                                {{#is object_type 'comment'}}
                                  <li class="text-gray-600">
                                    <a href={{url}}>
                                      {{t 'view_comment'}}
                                    </a>
                                  </li>
                                {{else}}
                                  <li class="text-gray-600">
                                    {{author.name}}
                                  </li>
                                {{/is}}
                                {{#if editor}}
                                  <li class="text-gray-600">
                                    {{#is object_type 'article'}}
                                      {{t 'updated'}}
                                    {{else}}
                                      {{t 'edited'}}
                                    {{/is}}
                                    {{date edited_at timeago=true}}
                                  </li>
                                {{else}}
                                  <li class="text-gray-600">
                                    {{date created_at timeago=true}}
                                  </li>
                                {{/if}}
                                {{#each stats}}
                                  <li class="text-gray-600">
                                    {{label}}
                                  </li>
                                {{/each}}
                                {{#isnt status 'none'}}
                                  <li class="text-gray-600">
                                    <span class="badge badge-{{status_dasherized}}">
                                      {{status_name}}
                                    </span>
                                  </li>
                                {{/isnt}}
                                {{#if pending}}
                                  <li class="text-gray-600">
                                    <span class="badge badge-pending">
                                      {{t 'pending_approval'}}
                                    </span>
                                  </li>
                                {{/if}}
                                {{#if official}}
                                  <li class="text-gray-600">
                                    <span class="badge badge-official">
                                      {{t 'official_comment'}}
                                    </span>
                                  </li>
                                {{/if}}
                              </ul>
                            {{/with}}
                          </div>
                        </li>
                      {{/each}}
                    </ul>
                  {{/if}}
                  {{#unless activities}}
                    <span class="text-gray-600 mt-4">
                      {{t 'no_contributions'}}
                    </span>
                  {{/unless}}
                {{/is}}

                {{! Badges overview }}
                {{#is current_filter.identifier 'badges'}}
                  {{#if user.badges}}
                    <header class="pt-4 pb-2 border-bottom">
                      <h3 class="mb-1">
                        {{t 'badges'}}
                      </h3>
                      <div class="md:flex justify-content-between align-items-baseline text-gray-600">
                        <p class="py-2 mb-2">
                          {{t 'badges_description' name=user.name}}
                        </p>
                      </div>
                    </header>

                    {{! Badges list }}
                    <ul class="list-unstyled list-bordered">
                      {{#each user.badges}}
                        <li class="media align-items-center py-2" aria-labelledby="title-{{id}}" aria-describedby="description-{{id}}">
                          {{#if icon_url}}
                            <img class="h-7 w-7 mr-4" src="{{icon_url}}" alt="{{name}}">
                          {{/if}}
                          <div class="media-body flex justify-content-between">
                            <div>
                              <h3 class="mt-4 mb-2" id="title-{{id}}">
                                {{name}}
                              </h3>
                              <p class="text-gray-600 font-size-md" id="description-{{id}}">
                                {{description}}
                              </p>
                            </div>
                            <div>
                              <div class="mt-4 mb-2">
                                {{t 'badges_awarded'}}
                              </div>
                              <p class="text-gray-600 font-size-md">
                                {{date assigned_at format='medium'}}
                              </p>
                            </div>
                          </div>
                        </li>
                      {{/each}}
                    </ul>
                  {{else}}
                    <p class="text-gray-600 mt-6">
                      {{t 'no_badges'}}
                    </p>
                  {{/if}}
                {{/is}}

                {{! Contributions overview (articles, posts and comments) }}
                {{#isnt current_filter.identifier 'activities'}}
                  {{#isnt current_filter.identifier 'badges'}}
                    {{#if contributions}}
                      <header class="pt-4 pb-2 border-bottom">
                        <h3 class="mb-1">
                          {{t current_filter.identifier}}
                        </h3>
                        {{#if sorters}}
                          <div class="md:flex justify-content-between align-items-baseline text-gray-600">
                            <p class="py-2 mb-0 md:mb-2">
                              {{sorter_description}}
                            </p>
                            <div class="dropdown mb-2" x-data="Widgets.dropdown" @click.away="close">
                              <button class="not-a-button py-2 cursor-pointer" aria-haspopup="true" :aria-expanded="isExpanded" x-ref="toggle">
                                {{current_sorter.label}}
                                <svg class="svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" aria-hidden="true" :class="{ 'rotate-180': isExpanded }">
                                  <use xlink:href="#icon-chevron-down" />
                                </svg>
                              </button>
                              <div class="dropdown-menu" role="menu" x-ref="menu" :aria-expanded="isExpanded">
                                {{#each sorters}}
                                  <a class="dropdown-item" href="{{url}}" aria-selected="{{selected}}" role="menuitem">
                                    {{name}}
                                  </a>
                                {{/each}}
                              </div>
                            </div>
                          </div>
                        {{/if}}
                      </header>

                      {{! Contributions list }}
                      <ul class="list-unstyled list-bordered">
                        {{#each contributions}}
                          <li class="py-4">
                            {{#isnt object_type 'comment'}}
                              <h3 class="h4 my-4">
                                <a href="{{url}}">
                                  {{title}}
                                </a>
                              </h3>
                            {{else}}
                              <nav aria-label="Contribution location">
                                <ol class="breadcrumbs mt-4">
                                  {{#each path_steps}}
                                    <li title="{{name}}">
                                      <a href="{{url}}">
                                        {{name}}
                                      </a>
                                    </li>
                                  {{/each}}
                                </ol>
                              </nav>
                            {{/isnt}}
                            <p>
                              {{excerpt body characters=200}}
                            </p>

                            {{! Contribution metadata }}
                            <ul class="list-divider">
                              {{#is object_type 'comment'}}
                                <li class="text-gray-600">
                                  <a href={{url}}>
                                    {{t 'view_comment'}}
                                  </a>
                                </li>
                              {{/is}}
                              {{#if editor}}
                                <li class="text-gray-600">
                                  {{#is object_type 'article'}}
                                    {{t 'updated'}}
                                  {{else}}
                                    {{t 'edited'}}
                                  {{/is}}
                                  {{date edited_at timeago=true}}
                                </li>
                              {{else}}
                                <li class="text-gray-600">
                                  {{date created_at timeago=true}}
                                </li>
                              {{/if}}
                              {{#each stats}}
                                <li class="text-gray-600">
                                  {{label}}
                                </li>
                              {{/each}}
                              {{#isnt status 'none'}}
                                <li class="text-gray-600">
                                  <span class="badge badge-{{status_dasherized}}">
                                    {{status_name}}
                                  </span>
                                </li>
                              {{/isnt}}
                              {{#if pending}}
                                <li class="text-gray-600">
                                  <span class="badge badge-pending">
                                    {{t 'pending_approval'}}
                                  </span>
                                </li>
                              {{/if}}
                              {{#if official}}
                                <li class="text-gray-600">
                                  <span class="badge badge-official">
                                    {{t 'official_comment'}}
                                  </span>
                                </li>
                              {{/if}}
                            </ul>
                          </li>
                        {{/each}}
                      </ul>

                      {{pagination}}

                    {{/if}}
                    {{#unless contributions}}
                      <p class="text-gray-600 mt-6">
                        {{t 'no_contributions'}}
                      </p>
                    {{/unless}}
                  {{/isnt}}
                {{/isnt}}
              </div>
            </section>
          {{/if}}

          {{#unless member_since}}
            <section class="card card-body bg-white profile-card">
              <p class="text-gray-600 mb-0">
                {{t 'no_content_yet'}}
              </p>
            </section>
          {{/unless}}
        {{/if}}

        {{#unless visible}}
          <section class="card card-body bg-white profile-card">
            <p class="text-gray-600 mb-0">
              {{t 'private_activity'}}
            </p>
          </section>
        {{/unless}}
      </main>
    </div>
  </div>
</div>

<script type="text/javascript">
  document.documentElement.classList.add('user-profile-page', 'user-' + {{user.id}});

  (function() {
    function withCacheBust(url) {
      if (!url) return url;
      var separator = url.indexOf('?') === -1 ? '?' : '&';
      return url + separator + 'cb=' + Date.now();
    }

    function refreshProfileAvatars() {
      var selectors = [
        '.profile-sidebar-avatar .avatar-img',
        '.profile-summary-row .avatar-img'
      ];

      var avatars = selectors
        .map(function(selector) { return document.querySelector(selector); })
        .filter(function(img) { return !!img; });

      if (!avatars.length) return;

      var fallbackHeader = document.querySelector('.user-menu .avatar-img');
      var fallbackHeaderSrc = fallbackHeader ? (fallbackHeader.getAttribute('src') || fallbackHeader.currentSrc || '') : '';

      avatars.forEach(function(img) {
        var initialSrc = img.getAttribute('src') || img.currentSrc || '';
        var baseSrc = fallbackHeaderSrc || initialSrc;
        if (!baseSrc) return;

        img.addEventListener('error', function onError() {
          if (img.dataset.avatarRetry === '1') return;
          img.dataset.avatarRetry = '1';
          var retrySrc = fallbackHeaderSrc || initialSrc;
          if (retrySrc) img.src = withCacheBust(retrySrc);
        });

        img.src = withCacheBust(baseSrc);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', refreshProfileAvatars, { once: true });
    } else {
      refreshProfileAvatars();
    }
  })();
</script>