<meta content="width=device-width, initial-scale=1.0" name="viewport" />
<meta
  name="theme-settings-fingerprint"
  content="hide_sign_in_link={{#if settings.hide_sign_in_link}}1{{else}}0{{/if}};show_submit_a_request_link={{#if settings.show_submit_a_request_link}}1{{else}}0{{/if}};show_article_submit_cta={{#if settings.show_article_submit_cta}}1{{else}}0{{/if}}">
<script type="text/javascript">window.Theme = Object.assign(window.Theme || {}, { assets: { emptyStateIcon: "{{asset 'Work-in-progress.svg'}}" }, locale: "{{help_center.locale}}", routes: { newRequest: "{{page_path 'new_request'}}" }, signedIn: {{signed_in}} });</script>
<script type="text/javascript" src="{{asset 'util.min.js'}}"></script>

{{! Extensions }}
<link rel="stylesheet" href="{{asset 'extension-animations.min.css'}}">
<link rel="stylesheet" href="{{asset 'extension-transitions.min.css'}}">
<link rel="stylesheet" href="https://use.fontawesome.com/releases/v6.4.0/css/all.css">
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

{{~#if settings.enable_video_player}}<link rel="stylesheet" href="{{asset 'extension-video.min.css'}}">{{/if~}}
{{~#if settings.enable_lightboxes}}<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/fancyapps/fancybox@3.5.7/dist/jquery.fancybox.min.css">
{{else}}{{~#if settings.promoted_video_ids}}<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/fancyapps/fancybox@3.5.7/dist/jquery.fancybox.min.css">{{/if~}}{{/if~}}
{{~#if settings.promoted_video_ids}}<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@7.0.9/swiper-bundle.min.css">{{~/if}}

{{! Settings-based styles }}
<style id="settings-styles">
  {{#unless settings.note_title}}
  .note::before { display: none; }
  {{else}}
    {{~#if settings.use_translations}}
    .note::before { content: "{{dc settings.note_title}}"; }
    {{/if~}}
  {{/unless}}
  {{#unless settings.warning_title}}
  .warning::before { display: none; }
  {{else}}
    {{~#if settings.use_translations}}
    .warning::before { content: "{{dc settings.warning_title}}"; }
    {{/if~}}
  {{/unless}}
  {{~#isnt settings.form_list_style 'standard'}}
  .request_ticket_form_id { display: none; }
  {{/isnt~}}
  {{#isnt settings.hero_element_shape 'none'}}
    {{#is settings.promoted_article_list_position 'after'}}
      {{#isnt settings.content_block_style 'none'}}
      .hero .svg-shape { fill: {{settings.bg_color_content_blocks}}; }
      {{/isnt}}
      {{#isnt settings.custom_block_style 'none'}}
      .hero .svg-shape { fill: {{settings.bg_color_custom_blocks}}; }
      {{/isnt}}
      {{~#is settings.notification_location 'home'}}
        {{~#if settings.notification_content}}
          .hero .svg-shape { fill: #fff; }
        {{/if~}}
      {{/is~}}
    {{/is}}
  {{/isnt}}
</style>

<style>
  :root {
    --theme-home-icon: url("{{asset 'home.svg'}}");
  }
</style>

<style>
  /* Auth-required: hidden until JS confirms signed-in */
  [data-requires-auth] { display: none !important; }
  .is-signed-in [data-requires-auth] { display: revert !important; }
</style>

{{! Fonts are hardcoded in style.css and local @font-face blocks below. }}
{{! ---------------------------------------------------------------
   CUSTOM FONTS: HILTI BRAND TYPEFACES
   Updated by: Kalidas, Janardhanan
   Timestamp: 20‑Mar‑2026 — 02:46 PM IST

   Purpose:
   - Registers Hilti corporate fonts for use across the Help Center
   - Ensures all weights/styles are declared cleanly
   - Uses theme asset files (uploaded via "Assets" in the theme editor)
---------------------------------------------------------------- }}

<style>
  /* -------------------------------------------------------------
     Hilti Small Roman — Regular (400)
  -------------------------------------------------------------- */
  @font-face {
    font-family: 'Hilti Small Roman';
    src: local('Hilti Small Roman'),
         url("{{asset 'HiltiSmallRoman.woff'}}") format('woff');
    font-weight: 400;
    font-style: normal;
    font-display: swap;     /* Improves loading performance */
  }

  /* -------------------------------------------------------------
     Hilti Small Bold — Bold (700)
  -------------------------------------------------------------- */
  @font-face {
    font-family: 'Hilti Small Bold';
    src: local('Hilti Small Bold'),
         url("{{asset 'HiltiSmallBold.woff'}}") format('woff');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  /* -------------------------------------------------------------
     Hilti Small Extended — Medium/Extended (500)
  -------------------------------------------------------------- */
  @font-face {
    font-family: 'Hilti Small Extended';
    src: local('Hilti Small Extended'),
         url("{{asset 'HiltiSmallExtended.woff'}}") format('woff');
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }

  /* -------------------------------------------------------------
     Hilti Small Heavy Extended — Heavy (900)
  -------------------------------------------------------------- */
  @font-face {
    font-family: 'Hilti Small Heavy Extended';
    src: local('Hilti Small Heavy Extended'),
         url("{{asset 'HiltiSmallHeavyExtended.woff'}}") format('woff');
    font-weight: 900;
    font-style: normal;
    font-display: swap;
  }
</style>

{{!--
  ---------------------------------------------------------
  File Name  : document_head.hbs
  Feature    : Category Icon Asset Injection (Zendesk Guide)
  ---------------------------------------------------------
  - Asset URLs are compiled server-side by Zendesk
  - scripts.js remains pure JavaScript
  - Category icon mapping is robust and maintainable

  Note:
  - This file MUST be used for any {{asset}} helper usage
  - No business logic is implemented here

  Updated by : Kalidas, Janardhanan
  Updated on : 13 Apr 2026, 18:07 IST
  Jira Ref   : FPSKB-128
  ---------------------------------------------------------
--}}

<script>
  window.CATEGORY_ICON_MAP = {
    // Category 1 – FAQ
    '45070746209937': "{{asset 'faq.svg'}}",

    // Category 2 – What’s New
    '43347810588945': "{{asset 'announcement.svg'}}",

    // Category 3 – Getting Started with PE
    '43357295486993': "{{asset 'Rocket.svg'}}",

    // Category 4 – PE Premium Subscription
    '43697046714897': "{{asset 'subscription.svg'}}",

    // Category 5 – Anchoring to Concrete
    '43697070376977': "{{asset 'Anchoring-to-Concrete.svg'}}",

    // Category 6 – Concrete to Concrete a.k.a. Post-installed rebar
    '43697123005969': "{{asset 'C2C_new.svg'}}",

    // Category 7 – Shear Strengthening
    '43697144515473': "{{asset 'Shear_Strengthening.svg'}}",

    // Category 8 – Concrete Overlay
    '45575806938897': "{{asset 'Concrete_Overlay.svg'}}",

    // Category 9 – Anchoring to Masonry
    '43697171088785': "{{asset 'Anchoring-to-Masonry.svg'}}",

    // Category 10 – Diaphragm Design
    '45069669042321': "{{asset 'Diaphragm_Design.svg'}}",

    // Category 11 – Concrete-over-metal-deck
    '45069633150481': "{{asset 'concrete-over-metal-deck.svg'}}",

    // Category 12 – Anchor Channel
    '43697241738129': "{{asset 'anchor_channel.svg'}}",

    // Category 13 – Facade
    '43697173115409': "{{asset 'Facade.svg'}}",

    // Category 14 – Glass Balustrade
    '43697227593105': "{{asset 'HIT_Glass.svg'}}",

    // Category 15 – Wood
    'To be updated': "{{asset 'Wood.svg'}}"

  };

  window.DEFAULT_CATEGORY_ICON =
    "{{asset 'broken.svg'}}";

  // Bridge: populate Theme.assets['category-{id}'] so the
  // content-blocks EJS template can render icons synchronously
  // without any DOMContentLoaded race condition.
  (function () {
    var map = window.CATEGORY_ICON_MAP;
    var assets = window.Theme && window.Theme.assets;
    if (!assets || !map) return;
    for (var id in map) {
      if (map.hasOwnProperty(id)) {
        assets['category-' + id] = map[id];
      }
    }
  })();
</script>