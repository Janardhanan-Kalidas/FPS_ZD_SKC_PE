{{! ================================================================
    LANGUAGE SWITCHER MODAL
    - Triggered by #hiltiLangTrigger in header
    - Hilti branded (red accent, clean grid)
    - Accessible: focus-trap, ESC close, aria attributes
    ================================================================ }}
{{~#if alternative_locales}}
<div class="hilti-lang-overlay" id="hiltiLangOverlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="hiltiLangTitle">
  <div class="hilti-lang-modal">
    <div class="hilti-lang-modal-header">
      <h2 id="hiltiLangTitle" class="hilti-lang-modal-title">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="#d0021b" aria-hidden="true">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
        </svg>
        Choose a Design Code
      </h2>
      <button class="hilti-lang-close" id="hiltiLangClose" type="button" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
          <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
        </svg>
      </button>
    </div>
    <div class="hilti-lang-modal-body">
      <ul class="hilti-lang-list hilti-region-list">

        {{!--
          REGION GROUP STRUCTURE
          ─────────────────────────────────────────────────────────────────
          Each keyword (ACI / EU) maps to one or more locales via data-locale.
          To add sub-languages under a region in future, replace the single
          <a data-locale="..."> with a <ul class="hilti-region-suboptions">
          containing one <a data-locale="..."> per language.
          The redirect handler in script.js picks up any [data-locale] element.

          Suggested future locales:
            ACI: es-419 (Spanish LatAm), pt-br (Portuguese BR)
            EU : de (German), fr (French), es-es (Spanish ES), it (Italian)
          ─────────────────────────────────────────────────────────────────
        --}}

        {{! ── ACI → en-us ── }}
        <li class="hilti-region-group">
          <a class="hilti-region-toggle" href="#" data-locale="en-us" rel="nofollow">
            <strong>ACI</strong>
          </a>
          {{! FUTURE: swap the <a> above for a toggle button + <ul class="hilti-region-suboptions"> }}
        </li>

        {{! ── EU → en-gb ── }}
        <li class="hilti-region-group">
          <a class="hilti-region-toggle" href="#" data-locale="en-gb" rel="nofollow">
            <strong>EU</strong>
          </a>
          {{! FUTURE: swap the <a> above for a toggle button + <ul class="hilti-region-suboptions"> }}
        </li>

      </ul>
    </div>
  </div>
</div>
{{/if~}}

{{!---------------
