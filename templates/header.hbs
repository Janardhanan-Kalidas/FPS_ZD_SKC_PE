          <div class="search flex text-base mx-4 mb-4 flex-first {{settings.nav_breakpoint}}:max-w-13 {{settings.nav_breakpoint}}:flex-1 {{settings.nav_breakpoint}}:mx-5 {{settings.nav_breakpoint}}:mb-0{{#isnt settings.header_search_style 'inline'}} {{settings.nav_breakpoint}}:hidden{{/isnt}}" x-data="Widgets.search">
            {{~#if settings.search_placeholder}}
              {{#if settings.use_translations}}
