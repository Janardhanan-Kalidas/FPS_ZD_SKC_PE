{{!--
  ============================================================================
  REDESIGNED SEARCH RESULTS PAGE
  ============================================================================
  Updated by: Kalidas, Janardhanan
  Updated on: 19 May 2026
  Purpose: Modern UX redesign with simplified filtering and improved layout
  
  Changes:
  - Removed Applications filter completely
  - Show only Categories in sidebar filter
  - Clean card/list layout for results
  - Highlight search keywords
  - Show result count and metadata
  - Empty state message
  - Responsive design with hover effects
  ============================================================================
--}}

{{! Breadcrumbs }}
<div class="bg-gray-100 pt-3 pb-2">
  <div class="container">
    <div class="row">
      <div class="col font-size-md">
        <div class="breadcrumbs-wrapper">
          <a href="{{help_center.url}}" class="bc-home">Home</a>
          <div class="bc-native">
            {{breadcrumbs}}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{{! Main Content Container }}
<div class="hc-search-container" id="page-container">
  <div class="hc-search-layout">

    {{! ===== LEFT SIDEBAR - FILTERS ===== }}
    <aside class="hc-search-sidebar">

      {{! Sidebar header: "Filter by" + Reset link }}
      <div class="hc-sidebar-header">
        <span class="hc-sidebar-title">Filter by</span>
        <a href="{{help_center.url}}search?utf8=✓&query={{query}}" class="hc-sidebar-reset">Reset</a>
      </div>

      {{! Types - from Zendesk type_filters }}
      {{#if type_filters}}
        <div class="hc-filter-section">
          <h3 class="hc-filter-title">Types</h3>
          <ul class="hc-filter-list">
            {{#each type_filters}}
              <li class="hc-filter-item">
                <a class="hc-filter-link{{#if selected}} hc-filter-active{{/if}}" href="{{url}}">
                  <span class="hc-filter-checkbox" aria-hidden="true"></span>
                  <span class="hc-filter-name">{{name}}</span>
                  {{#if count}}<span class="hc-filter-count">({{count}})</span>{{/if}}
                </a>
              </li>
            {{/each}}
          </ul>
        </div>
      {{/if}}

      {{! Categories - built by JavaScript from rendered result breadcrumbs }}
      <div class="hc-filter-section" id="hc-category-filter">
        <h3 class="hc-filter-title">Sections</h3>
        <ul class="hc-filter-list" id="hc-category-list">
          {{! Populated by JavaScript from rendered results }}
        </ul>
      </div>

    </aside>

    {{! ===== MAIN CONTENT - RESULTS ===== }}
    <section class="hc-search-main">
      
      {{! Results Header with Count }}
      <div class="hc-results-header">
        <h1 class="hc-results-title">
          {{#if query}}
            {{#if results}}
              Showing <strong>{{results_count}}</strong> results for "{{query}}"
              {{#is current_filter.identifier 'unified'}}
                in all categories
              {{else}}
                in {{current_filter.name}}
              {{/is}}
            {{else}}
              No results for "<strong>{{query}}</strong>"
            {{/if}}
          {{else}}
            Search Results
          {{/if}}
        </h1>
        
        {{! Sort dropdown }}
        {{#if results}}
          <div class="hc-sort-dropdown">
            <label for="sortSelect" class="sr-only">Sort by</label>
            <select id="sortSelect" class="hc-sort-select">
              <option value="relevance">Most Relevant</option>
              <option value="recent">Most Recent</option>
            </select>
          </div>
        {{/if}}
      </div>

      {{! Generative Answers }}
      {{generative_answers}}

      {{! Results List }}
      {{#if results}}
        <div class="hc-results-list">
          {{#each results}}
            <article class="hc-result-card">
              
              {{! Article Title }}
              <h2 class="hc-result-title">
                <a href="{{url}}" class="hc-result-link"{{#if is_external}} target="_blank" rel="noopener"{{/if}}>
                  {{title}}
                  {{#if is_external}}
                    <svg class="hc-external-icon" viewBox="0 0 12 12" width="14" height="14" aria-label="External link">
                      <path fill="none" stroke="currentColor" stroke-linecap="round" d="M10.5 8.5V10c0 .28-.22.5-.5.5H2c-.28 0-.5-.22-.5-.5V2c0-.28.22-.5.5-.5h1.5M6 6l4-4"></path>
                      <path fill="currentColor" d="M10.5 6.5a.47.47 0 0 1-.35-.15l-4.5-4.5a.474.474 0 0 1-.11-.54C5.62 1.12 5.8 1 6 1h4c.55 0 1 .45 1 1v4c0 .2-.12.38-.31.46-.06.03-.13.04-.19.04z"></path>
                    </svg>
                  {{/if}}
                </a>
              </h2>

              {{! Category breadcrumb }}
              {{#if path_steps}}
                <div class="hc-result-category">
                  {{#each path_steps}}
                    {{#unless @first}}
                      <span class="hc-category-separator">›</span>
                    {{/unless}}
                    <a href="{{url}}" class="hc-category-link">{{name}}</a>
                  {{/each}}
                </div>
              {{/if}}

              {{! Article Snippet/Description }}
              {{#if text}}
                <p class="hc-result-snippet">{{text}}</p>
              {{/if}}

              {{! Metadata Footer }}
              <div class="hc-result-meta">
                {{! Last Updated Date }}
                <span class="hc-meta-item">
                  <svg class="hc-meta-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" width="14" height="14" aria-hidden="true">
                    <circle cx="6" cy="6" r="5.5" fill="none" stroke="currentColor"/>
                    <path stroke="currentColor" stroke-linecap="round" d="M6 3v3.5L8 8"/>
                  </svg>
                  Updated {{date created_at}}
                </span>

                {{! Vote Count }}
                {{#if vote_sum}}
                  <span class="hc-meta-item">
                    <svg class="hc-meta-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" aria-hidden="true">
                      <g fill="none" stroke="currentColor">
                        <path stroke-linejoin="round" d="M10.77 4.5a.73.73 0 01.73.73C11.43 7 11.21 11.5 10 11.5H5a.5.5 0 01-.5-.5V4.5s1-.5 1-3a1 1 0 012 0v3z"/>
                        <rect width="2" height="7" x=".5" y="4.5" rx=".5" ry=".5"/>
                      </g>
                    </svg>
                    {{vote_sum}} helpful
                  </span>
                {{/if}}

                {{! Comment Count }}
                {{#if comment_count}}
                  <span class="hc-meta-item">
                    <svg class="hc-meta-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" aria-hidden="true">
                      <path fill="none" stroke="currentColor" d="M1 .5h10c.3 0 .5.2.5.5v7c0 .3-.2.5-.5.5H6l-2.6 2.6c-.3.3-.9.1-.9-.4V8.5H1C.7 8.5.5 8.3.5 8V1C.5.7.7.5 1 .5z"/>
                    </svg>
                    {{comment_count}} comments
                  </span>
                {{/if}}
              </div>

            </article>
          {{/each}}
        </div>

        {{! Pagination }}
        <div class="hc-pagination-wrapper">
          {{pagination}}
        </div>

      {{else}}
        {{! Empty State }}
        <div class="hc-empty-state">
          <svg class="hc-empty-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="80" height="80">
            <circle cx="32" cy="32" r="30" fill="none" stroke="#e0e0e0" stroke-width="2"/>
            <circle cx="25" cy="28" r="4" fill="#999"/>
            <circle cx="39" cy="28" r="4" fill="#999"/>
            <path d="M20 42c0-6.6 5.4-12 12-12s12 5.4 12 12" fill="none" stroke="#999" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <h2 class="hc-empty-title">No results found</h2>
          <p class="hc-empty-text">
            Try different keywords or browse our
            {{#link 'help_center'}}
              help center
            {{/link}}
          </p>
        </div>
      {{/if}}

    </section>

  </div>
</div>

{{! Add search results page class for styling }}
<script>document.documentElement.classList.add('search-results-page')</script>

{{! Keyword Highlighting Script }}
<script>
(function() {
  'use strict';
  
  // Highlight search keywords in results
  var query = '{{query}}'.trim();
  if (!query) return;
  
  var keywords = query.split(/\s+/).filter(function(k) { return k.length > 2; });
  if (!keywords.length) return;
  
  var pattern = new RegExp('(' + keywords.map(function(k) {
    return k.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }).join('|') + ')', 'gi');
  
  document.querySelectorAll('.hc-result-title, .hc-result-snippet').forEach(function(el) {
    var html = el.innerHTML;
    el.innerHTML = html.replace(pattern, '<mark class="hc-highlight">$1</mark>');
  });

  // Sort select - robust URL param manipulation
  var sortSelect = document.getElementById('sortSelect');
  if (sortSelect) {
    if (window.location.search.indexOf('sort_by=created_at') !== -1) {
      sortSelect.value = 'recent';
    }
    sortSelect.addEventListener('change', function() {
      var href = window.location.href;
      var hashIdx = href.indexOf('#');
      var hash = hashIdx > -1 ? href.substring(hashIdx) : '';
      if (hashIdx > -1) href = href.substring(0, hashIdx);
      var parts = href.split('?');
      var urlBase = parts[0];
      var params = parts[1] ? parts[1].split('&').filter(function(p) {
        return p && p.indexOf('sort_by=') !== 0 && p.indexOf('sort_order=') !== 0;
      }) : [];
      if (this.value === 'recent') {
        params.push('sort_by=created_at');
        params.push('sort_order=desc');
      }
      window.location.href = urlBase + (params.length ? '?' + params.join('&') : '') + hash;
    });
  }

  // Build category checkboxes with client-side filtering
  (function() {
    var catList = document.getElementById('hc-category-list');
    var catSection = document.getElementById('hc-category-filter');
    var cards = document.querySelectorAll('.hc-result-card');

    if (!catList || !catSection || !cards.length) return;

    var cardCats = [];
    var catCounts = {};

    for (var i = 0; i < cards.length; i++) {
      var catLinks = cards[i].querySelectorAll('.hc-result-category .hc-category-link');
      var cn = catLinks.length ? catLinks[catLinks.length - 1].textContent.trim() : null;
      cardCats.push(cn);
      if (cn) catCounts[cn] = (catCounts[cn] || 0) + 1;
    }

    var catNames = Object.keys(catCounts).sort();
    if (!catNames.length) {
      catSection.style.display = 'none';
      return;
    }

    catNames.forEach(function(cat) {
      var li = document.createElement('li');
      li.className = 'hc-filter-item';

      var label = document.createElement('label');
      label.className = 'hc-filter-link';

      var input = document.createElement('input');
      input.type = 'checkbox';
      input.className = 'hc-filter-input';
      input.value = cat;

      var box = document.createElement('span');
      box.className = 'hc-filter-checkbox';
      box.setAttribute('aria-hidden', 'true');

      var nameEl = document.createElement('span');
      nameEl.className = 'hc-filter-name';
      nameEl.textContent = cat;

      var countEl = document.createElement('span');
      countEl.className = 'hc-filter-count';
      countEl.textContent = '(' + catCounts[cat] + ')';

      label.appendChild(input);
      label.appendChild(box);
      label.appendChild(nameEl);
      label.appendChild(countEl);
      li.appendChild(label);
      catList.appendChild(li);
    });

    function applyFilter() {
      var checked = [];
      var inputs = catList.querySelectorAll('.hc-filter-input');
      for (var k = 0; k < inputs.length; k++) {
        var lbl = inputs[k].parentElement;
        var chkBox = lbl ? lbl.querySelector('.hc-filter-checkbox') : null;
        if (inputs[k].checked) {
          checked.push(inputs[k].value);
          if (lbl) lbl.classList.add('hc-filter-active');
          if (chkBox) chkBox.classList.add('is-checked');
        } else {
          if (lbl) lbl.classList.remove('hc-filter-active');
          if (chkBox) chkBox.classList.remove('is-checked');
        }
      }
      for (var n = 0; n < cards.length; n++) {
        if (!checked.length || checked.indexOf(cardCats[n]) > -1) {
          cards[n].style.display = '';
        } else {
          cards[n].style.display = 'none';
        }
      }
    }

    catList.addEventListener('change', applyFilter);
  })();
})();
</script>
