# Copy this file to .env.local and fill values locally.
# .env.local is ignored by git.

ATLASSIAN_BASE_URL=https://hilti.atlassian.net
CONFLUENCE_SPACE_KEY=BFS
CONFLUENCE_PARENT_PAGE_ID=2900984544
ATLASSIAN_USER_EMAIL=your.name@hilti.com
ATLASSIAN_API_TOKEN=replace_with_atlassian_api_token

# Optional overrides for Keychain lookup fallback
# ATLASSIAN_KEYCHAIN_SERVICE_NAME=atlassian_api_token_hilti
# ATLASSIAN_KEYCHAIN_ACCOUNT_NAME=$USER
